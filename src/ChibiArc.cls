Public Property Get AutoDismountOnTerminate() As Boolean
  ' When True, Class_Terminate fully detaches any mounted ISO (releasing the
  ' drive letter and raising IsoDismounted) as the object goes out-of-scope.
  ' When False (the default), a mount created via MountISO deliberately
  ' survives the object, because the disk is attached with PERMANENT_LIFETIME.
  AutoDismountOnTerminate = m_AutoDismountOnTerminate
End Property

Public Property Let AutoDismountOnTerminate(ByVal val As Boolean)
  m_AutoDismountOnTerminate = val
End Property

Public Sub Add(ByVal Source As Variant, Optional ByVal DestinationInArchive As String = "")
  Dim batchDest As String
  If Not AssertMode(arcModeWrite, "Add") Then Exit Sub
  Select Case VarType(Source)
  Case vbString
    Dim path As String: path = CStr(Source)
    If Len(path) = 0 Then
      LogMessage logWarning, "Add: empty source ignored."
      Exit Sub
    End If
    If FolderExists(path) Then
      AddFolderRecursive path, DestinationInArchive
    ElseIf FileExists(path) Then
      AddFileEntry path, DestinationInArchive
    ElseIf Not IsRootedPath(path) Then
      ' Bare name or relative path   treat as virtual folder creation
      Dim folderName As String
      folderName = NormaliseEntryName(path)
      If VBA.Right$(folderName, 1) <> "/" Then folderName = folderName & "/"
      QueueFolder folderName
      LogMessage logDebug, "Queued virtual folder: " & folderName
    Else
      ' Rooted path that doesn't exist   genuine missing file
      LogMessage logWarning, "[Add] source not found: " & path
      AppendReport "FAILED : " & path & " - not found"
    End If
  Case vbArray + vbByte, vbByte Or vbArray
    If Len(DestinationInArchive) = 0 Then
      LogMessage logWarning, "[Add} DestinationInArchive required for byte array sources."
      AppendReport "FAILED : (byte array) - no destination name supplied"
      Exit Sub
    End If
    Dim baData() As Byte: baData = Source
    QueueBytes NormaliseEntryName(DestinationInArchive), baData
  Case vbArray + vbString
    batchDest = DestinationInArchive
    If Len(batchDest) > 0 And VBA.Right$(batchDest, 1) <> "/" Then
      batchDest = batchDest & "/"
    End If
    Dim i As Long
    For i = LBound(Source) To UBound(Source)
      Dim s As String
      s = CStr(Source(i))
      If Len(Trim$(s)) > 0 Then Add s, batchDest
    Next
  Case vbArray + vbVariant
    Dim j As Long

    batchDest = DestinationInArchive
    If Len(batchDest) > 0 And VBA.Right$(batchDest, 1) <> "/" Then
      batchDest = batchDest & "/"
    End If
    For j = LBound(Source) To UBound(Source)
      If VarType(Source(j)) = vbString Then
        If Len(Trim$(CStr(Source(j)))) > 0 Then Add Source(j), batchDest
      End If
    Next
  Case vbObject
    If TypeOf Source Is Collection Then
      Dim item As Variant
      batchDest = DestinationInArchive
      If Len(batchDest) > 0 And VBA.Right$(batchDest, 1) <> "/" Then
        batchDest = batchDest & "/"
      End If
      For Each item In Source
        If VarType(item) = vbString Then
          If Len(Trim$(CStr(item))) > 0 Then Add item, batchDest
        End If
      Next
    Else
      LogMessage logWarning, "[Add] unsupported object type (" & TypeName(Source) & ")."
    End If
  Case vbEmpty, vbNull
    LogMessage logWarning, "[Add] empty source ignored."
  Case Else
    On Error Resume Next
    Dim sPath As String: sPath = CStr(Source)
    On Error GoTo 0
    If Len(sPath) > 0 Then
      Add sPath, DestinationInArchive
    Else
      LogMessage logWarning, "[Add] unsupported source type (" & TypeName(Source) & ")."
    End If
  End Select
End Sub

Public Sub AddNew(ByVal name As String, Optional ByVal ParentPath As String = "")
  ' Creates an explicit folder entry in the archive.
  ' This is useful to establish folder structure before or after populating it,
  ' or to create intentionally empty folders.
  ' Name       : the folder name (e.g. "reports" or "2024/Q1")
  ' ParentPath : optional prefix (e.g. "output/") - trailing slash normalised
  If Not AssertMode(arcModeWrite, "AddNew") Then Exit Sub
  If Len(name) = 0 Then
    LogMessage logWarning, "[AddNew] Empty name ignored."
    Exit Sub
  End If
  Dim fullPath As String
  If Len(ParentPath) > 0 Then
    fullPath = RemoveTrailingSlash(ParentPath) & "/" & name
  Else
    fullPath = name
  End If
  Add fullPath
End Sub

Private Function OpenLibArchive(ByVal filePath As String) As Boolean
  m_hRead = archive_read_new()
  If m_hRead = 0 Then
    SetError "[OpenLibArchive] archive_read_new failed"
    Exit Function
  End If

  archive_read_support_format_all m_hRead
  archive_read_support_filter_all m_hRead

  Dim UTF8() As Byte
  UTF8 = ToUtf8Z(filePath)
  If archive_read_open_filename(m_hRead, VarPtr(UTF8(0)), 65536) <> ARCHIVE_OK Then
    SetError "[OpenLibArchive] archive_read_open_filename failed"
    archive_read_free m_hRead
    m_hRead = 0
    Exit Function
  End If

  OpenLibArchive = True
End Function

Private Function SaveLibArchive() As Boolean
  If Not InitWriteArchive() Then Exit Function

  Dim utf8Path() As Byte
  utf8Path = ToUtf8Z(m_SourceFile)
  If archive_write_open_filename(m_hWrite, VarPtr(utf8Path(0))) <> ARCHIVE_OK Then
    SetError "[SaveLibArchive] archive_write_open_filename failed"
    archive_write_free m_hWrite
    m_hWrite = 0
    Exit Function
  End If

  If Not WriteAllEntries() Then
    CloseLibArchive
    Exit Function
  End If

  If archive_write_close(m_hWrite) <> ARCHIVE_OK Then
    SetError "[SaveLibArchive] archive_write_close failed"
    archive_write_free m_hWrite
    m_hWrite = 0
    Exit Function
  End If

  archive_write_free m_hWrite
  m_hWrite = 0
  SaveLibArchive = True
End Function

Private Sub CloseLibArchive()
  If m_hRead <> 0 Then
    archive_read_close m_hRead
    archive_read_free m_hRead
    m_hRead = 0
  End If
  If m_hWrite <> 0 Then
    archive_write_close m_hWrite
    archive_write_free m_hWrite
    m_hWrite = 0
  End If
  m_hEntry = 0
End Sub

Private Sub ResetState()
  m_Mode = arcModeNone
  m_Type = atAuto
  m_hEntry = 0
  m_QueueCount = 0
  Erase m_Queue
  m_Scanned = False
  m_ScanCount = 0
  Erase m_ScanEntries
  m_FileCount = 0
  m_FolderCount = 0
  m_IsEncrypted = False
  m_DetectedEncryption = aeNone
  m_SourceFile = ""
  m_Passphrase = ""
  m_ConflictMode = acmReject
  m_Encryption = aeNone
  m_CompressionLevel = 6
  m_SkipCompressedTypes = False
  m_LastError = ""
  Set m_FolderIndex = Nothing
End Sub

Private Function InitWriteArchive() As Boolean
  ' Creates and configures the libarchive write handle: format, filter, compression level, passphrase
  ' (ZipCrypto / libarchive-native encryption), and options. Called for every non-AES write path.
  m_hWrite = archive_write_new()
  If m_hWrite = 0 Then
    SetError "[InitWriteArchive] archive_write_new failed"
    Exit Function
  End If

  Dim fmtOk As Long
  Select Case m_Type
  Case atZip
    fmtOk = archive_write_set_format_zip(m_hWrite)
  Case at7Zip
    fmtOk = archive_write_set_format_7zip(m_hWrite)
  Case atTar, atTarGz, atTarBz2, atTarXz, atTarZst
    fmtOk = archive_write_set_format_ustar(m_hWrite)
  Case atTarPax
      fmtOk = archive_write_set_format_pax(m_hWrite)
  Case atTarPaxRestricted
      fmtOk = archive_write_set_format_pax_restricted(m_hWrite)
  Case atTarGnu
      fmtOk = archive_write_set_format_gnutar(m_hWrite)
  Case atCpio
    fmtOk = archive_write_set_format_cpio(m_hWrite)
  Case atXar
    fmtOk = archive_write_set_format_xar(m_hWrite)
  Case atIso
    fmtOk = archive_write_set_format_iso9660(m_hWrite)
  Case Else
    SetError "[InitWriteArchive] Unsupported archive type: " & ArchiveTypeName(m_Type)
    archive_write_free m_hWrite: m_hWrite = 0
    Exit Function
  End Select

  If fmtOk <> ARCHIVE_OK Then
    SetError "[InitWriteArchive] Failed to set archive format: " & ArchiveTypeName(m_Type)
    archive_write_free m_hWrite
    m_hWrite = 0
    Exit Function
  End If

  Select Case m_Type
  Case atTarGz
    archive_write_add_filter_gzip m_hWrite
  Case atTarBz2
    archive_write_add_filter_bzip2 m_hWrite
  Case atTarXz
    archive_write_add_filter_xz m_hWrite
  Case atTarZst
    archive_write_add_filter_zstd m_hWrite
  Case Else
    archive_write_add_filter_none m_hWrite
  End Select

  ' Build the ZIP/format module options as a single combined comma-separated
  ' string. NOTE: libarchive's option parser can reject (or silently ignore)
  ' a second archive_write_set_options call targeting the same module once
  ' the first has been applied, so all options for a given module are
  ' batched into one call here rather than issued as separate SetWriteOption
  ' calls (which the prior version of this function did for compression
  ' level and zip:encryption=traditional).
  Dim combinedOpts As String

  If m_CompressionLevel > 0 Then
    Dim prefix As String
    Select Case m_Type
    Case atZip: prefix = "zip"
    Case at7Zip: prefix = "7zip"
    Case atTarGz: prefix = "gzip"
    Case atTarBz2: prefix = "bzip2"
    Case atTarXz: prefix = "xz"
    Case atTarZst: prefix = "zstd"
    End Select
    If Len(prefix) > 0 Then
      combinedOpts = AppendOpt(combinedOpts, prefix & ":compression-level=" & m_CompressionLevel)
    End If
  End If

  ' This point is very important.
  ' zip:hdrcharset=UTF-8 forces libarchive to treat entry names as UTF-8
  ' end-to-end when formatting the Local File Header / Central Directory
  ' Header, rather than attempting an internal charset/codepage conversion.
  ' That internal conversion path has been observed to crash inside
  ' archive_write_header on this archiveint.dll build when an entry name
  ' contains non-ASCII characters (repro: CJK filename + ZipCrypto write).
  If m_Type = atZip Then
    combinedOpts = AppendOpt(combinedOpts, "zip:hdrcharset=UTF-8")
  End If

  If m_Type = atZip And m_Encryption = aeZipCrypto And Len(m_Passphrase) > 0 Then
    combinedOpts = AppendOpt(combinedOpts, "zip:encryption=traditional")
  End If

  ' EXPERIMENT (v1.1): explicitly enable the iso9660 name-extension records.
  ' The bare iso9660 writer relies on defaults; a purely-non-ASCII path segment
  ' (e.g. a folder named in CJK) was observed to be silently dropped from the
  ' image along with its entire subtree, because base ISO 9660 has no valid
  ' name for it. Rock Ridge stores full POSIX/UTF-8 names and is the extension
  ' most likely to carry arbitrary non-ASCII names; Joliet is the Windows-native
  ' extension the mount path reads. Enabling both explicitly (rather than
  ' trusting defaults) is the thing under test here.
  If m_Type = atIso Then
    combinedOpts = AppendOpt(combinedOpts, "iso9660:rockridge")
    combinedOpts = AppendOpt(combinedOpts, "iso9660:joliet")
  End If

  If Len(combinedOpts) > 0 Then SetWriteOption combinedOpts

  ' Passphrase needs to precede the setting of the encryption option
  If Len(m_Passphrase) > 0 Then
    Dim pwd() As Byte
    pwd = ToUtf8Z(m_Passphrase)
    If archive_write_set_passphrase(m_hWrite, VarPtr(pwd(0))) <> ARCHIVE_OK Then
      SetError "[InitWriteArchive] Failed to set passphrase"
      archive_write_free m_hWrite
      m_hWrite = 0
      Exit Function
    End If
  End If

  InitWriteArchive = True
End Function

Private Function AppendOpt(ByVal existing As String, ByVal newOpt As String) As String
  ' Appends an "option=value" fragment to a comma-separated options string,
  ' used to batch multiple options for the same libarchive module into a
  ' single archive_write_set_options call.
  If Len(existing) = 0 Then
    AppendOpt = newOpt
  Else
    AppendOpt = existing & "," & newOpt
  End If
End Function

Private Function StringToGuid(ByVal value As String) As guid
  Dim guid As guid
  If CLSIDFromString(StrPtr(value), guid) = S_OK Then StringToGuid = guid
End Function

Private Function CutNull(ByVal sStr As String) As String
  Dim p As Long
  p = InStr(1, sStr, vbNullChar)
  If p > 0 Then
    CutNull = Left$(sStr, p - 1)
  Else
    CutNull = sStr
  End If
End Function

Private Function GetDriveLetterFromDevicePath(ByVal devicePath As String) As String
  Dim volumeName As String, letters As String, returnedLength As Long
  volumeName = String$(MAX_PATH, vbNullChar)
  If GetVolumeNameForVolumeMountPointW(StrPtr(devicePath & "\"), StrPtr(volumeName), MAX_PATH) = 1 Then
    letters = String$(MAX_PATH, vbNullChar)
    If GetVolumePathNamesForVolumeNameW(StrPtr(CutNull(volumeName)), StrPtr(letters), MAX_PATH, returnedLength) = 1 Then
      GetDriveLetterFromDevicePath = CutNull(letters)
    End If
  End If
End Function

Private Function GetVolumeNameFromDevicePath(ByVal devicePath As String) As String
  Dim volumeName As String
  volumeName = String$(MAX_PATH, vbNullChar)
  If Right$(devicePath, 1) <> "\" Then devicePath = devicePath & "\"
  If GetVolumeNameForVolumeMountPointW(StrPtr(devicePath), StrPtr(volumeName), MAX_PATH) = 1 Then
    GetVolumeNameFromDevicePath = CutNull(volumeName)
  End If
End Function

Private Function TryGetExistingMount(ByVal isoPath As String) As String
  Dim mounted() As String
  mounted = GetAllMountedIsoPaths()
  Dim i As Long

  For i = LBound(mounted) To UBound(mounted)
    If StrComp(mounted(i), isoPath, vbTextCompare) = 0 Then
      Dim tVst As VIRTUAL_STORAGE_TYPE
      Dim tOvdp As OPEN_VIRTUAL_DISK_PARAMETERS
      Dim hDisk As LongPtr
      Dim pathBuffer As String
      Dim pathSize As Long

      tVst.DeviceId = VIRTUAL_STORAGE_TYPE_DEVICE_ISO
      tVst.VendorId = StringToGuid(VIRTUAL_STORAGE_TYPE_VENDOR_MICROSOFT)
      tOvdp.Version = OPEN_VIRTUAL_DISK_VERSION_1
      tOvdp.RWDepth = OPEN_VIRTUAL_DISK_RW_DEPTH_DEFAULT

      If OpenVirtualDisk(VarPtr(tVst), StrPtr(isoPath), VIRTUAL_DISK_ACCESS_GET_INFO, 0&, VarPtr(tOvdp), hDisk) = S_OK Then
        pathSize = MAX_PATH * 2
        pathBuffer = String$(MAX_PATH, vbNullChar)
        If GetVirtualDiskPhysicalPath(hDisk, pathSize, StrPtr(pathBuffer)) = S_OK Then
          TryGetExistingMount = GetDriveLetterFromDevicePath(CutNull(pathBuffer))
        End If
        apiCloseHandle hDisk
      End If
      Exit Function
    End If
  Next i
End Function

Private Function GetAllMountedIsoPaths() As String()
  Dim result() As String
  ReDim result(-1 To -1)

  Dim sizeBytes As Long, status As Long, buffer As String, pBuffer As LongPtr, parts() As String, i As Long, count As Long
  sizeBytes = 0
  pBuffer = 0

  Do
    status = GetAllAttachedVirtualDiskPhysicalPaths(sizeBytes, pBuffer)
    If status = ERROR_INSUFFICIENT_BUFFER Then
      buffer = String$(sizeBytes \ 2, vbNullChar)
      pBuffer = StrPtr(buffer)
    Else
      Exit Do
    End If
  Loop

  If status <> ERROR_SUCCESS Or sizeBytes = 0 Then
    GetAllMountedIsoPaths = result
    Exit Function
  End If

  parts = Split(buffer, vbNullChar)
  For i = LBound(parts) To UBound(parts)
    If Len(parts(i)) > 0 Then
      If UCase$(VBA.Right$(parts(i), 4)) = ".ISO" Then
        If count = 0 Then
          ReDim result(0 To 0)
        Else
          ReDim Preserve result(0 To count)
        End If
        result(count) = CutNull(parts(i))
        count = count + 1
      End If
    End If
  Next i

  If count = 0 Then ReDim result(-1 To -1)
  GetAllMountedIsoPaths = result
End Function

Private Function WriteAllEntries() As Boolean
  ' Iterates the queue and writes each entry through the open libarchive handle.
  ' Errors are logged to OperationReport but do not abort the archive; processing
  ' continues so that as many entries as possible are written.
  Dim i As Long, ok As Boolean
  Dim reportLines() As String, rCount As Long
  ReDim reportLines(0 To m_QueueCount - 1)
  ok = True

  RaiseEvent ProgressEvent("Writing " & m_QueueCount & " entries", 0)

  For i = 0 To m_QueueCount - 1
    If m_ProgressInterval > 0 And (i Mod m_ProgressInterval) = 0 Then
      RaiseEvent ProgressEvent("Writing: " & m_Queue(i).name, CLng((i + 1) / m_QueueCount * 100))
    End If

    If Not WriteOneEntry(m_Queue(i)) Then
      Dim failLine As String
      failLine = "FAILED : " & m_Queue(i).name & " - " & m_LastError
      LogMessage logWarning, failLine

      reportLines(rCount) = failLine
      rCount = rCount + 1
      ok = False
    Else
      Dim passLine As String
      passLine = "OK     : " & m_Queue(i).name

      ' Accumulate size for UncompressedSize / CompressedSize properties.
      ' For byte-array entries the uncompressed size is known immediately;
      ' for file entries we read it from disk (returns -1 on failure, ignored).
      If m_Queue(i).isFolder = False Then
        If Len(m_Queue(i).SourcePath) > 0 Then
          Dim fsz As LongLong
          fsz = m_Queue(i).FileSize
          If fsz >= 0 Then m_TotalUncompressedSize = m_TotalUncompressedSize + fsz
        ElseIf IsByteArrayUsable(m_Queue(i).data) Then
          m_TotalUncompressedSize = m_TotalUncompressedSize + CLngLng(UBound(m_Queue(i).data) - LBound(m_Queue(i).data) + 1)
        End If
      End If

      reportLines(rCount) = passLine
      rCount = rCount + 1
    End If
  Next
  If rCount > 0 Then m_OperationReport = Join(reportLines, vbCrLf)
  RaiseEvent ProgressEvent("Completed", 100)
  WriteAllEntries = ok
End Function

Private Function WriteOneEntry(ByRef e As QueueEntry) As Boolean
  ' Writes a single QueueEntry through the libarchive write handle.
  ' Folders are written as zero-size directory entries.
  ' Files are written either from disk (streamed in chunks) or from Data().
  On Error GoTo ErrHandler

  Dim hEntry As LongPtr:
  hEntry = archive_entry_new()
  If hEntry = 0 Then
    SetError "[WriteOneEntry] archive_entry_new failed: " & e.name
    Exit Function
  End If

  Dim utf8Name() As Byte, t As Long
  utf8Name = ToUtf8Z(e.name)
  archive_entry_set_pathname_utf8 hEntry, VarPtr(utf8Name(0))

  t = DateToUnix(e.ModifiedDate)
  archive_entry_set_mtime hEntry, t, 0
  archive_entry_set_atime hEntry, t, 0
  archive_entry_set_ctime hEntry, t, 0

  If e.isFolder Then
    archive_entry_set_filetype hEntry, AE_IFDIR
    archive_entry_set_perm hEntry, DEFAULT_PERM_DIR
    archive_entry_set_size hEntry, 0
    ' TODO: check against CJK text used in folders/files for generated ISOs
    '   Dim hdrRc As Long
    '   hdrRc = archive_write_header(m_hWrite, hEntry)
    '   If hdrRc <> ARCHIVE_OK Then
    '     LogMessage logWarning, "[WriteOneEntry] folder header rc=" & hdrRc & " for: " & e.name & IIf(Len(LastArchiveError(m_hWrite)) > 0, " (" & LastArchiveError(m_hWrite) & ")", "")
    '   End If
    archive_write_header m_hWrite, hEntry
    archive_entry_free hEntry
    archive_write_finish_entry m_hWrite
    WriteOneEntry = True
    Exit Function
  End If

  archive_entry_set_filetype hEntry, AE_IFREG
  archive_entry_set_perm hEntry, DEFAULT_PERM_FILE

  If e.IsStreamed Or (Len(e.SourcePath) > 0 And Not IsByteArrayUsable(e.data)) Then
    ' Stream from disk
    Dim sz As LongLong
    sz = GetFileSize64(e.SourcePath)
    If sz < 0 Then sz = 0
    archive_entry_set_size hEntry, sz
    If archive_write_header(m_hWrite, hEntry) <> ARCHIVE_OK Then
      SetError "[WriteOneEntry] archive_write_header failed: " & e.name
      GoTo CleanUp
    End If
    If Not StreamFileToDisk(e.SourcePath) Then GoTo CleanUp
    archive_write_finish_entry m_hWrite
  Else
    ' From in-memory Data()
    Dim dataLen As Long
    If IsByteArrayUsable(e.data) Then dataLen = UBound(e.data) - LBound(e.data) + 1
    archive_entry_set_size hEntry, dataLen
    If archive_write_header(m_hWrite, hEntry) <> ARCHIVE_OK Then
      SetError "[WriteOneEntry] archive_write_header failed: " & e.name
      GoTo CleanUp
    End If
    If dataLen > 0 Then
      Dim written As LongPtr
      written = archive_write_data(m_hWrite, VarPtr(e.data(LBound(e.data))), dataLen)
      If written < 0 Then
        SetError "[WriteOneEntry] archive_write_data failed: " & e.name
        GoTo CleanUp
      End If
    End If
    archive_write_finish_entry m_hWrite
  End If

  archive_entry_free hEntry
  WriteOneEntry = True
  Exit Function

CleanUp:
  archive_entry_free hEntry
  Exit Function

ErrHandler:
  SetError "[WriteOneEntry] WriteOneEntry crashed: " & e.name & " - " & Err.Description
  Resume CleanUp
End Function

Private Function StreamFileToDisk(ByVal SourcePath As String) As Boolean
  ' Reads SourcePath in STREAM_CHUNK_SIZE chunks and feeds each block to the open libarchive write handle.
  ' Zero-byte file: nothing to stream; libarchive handles the empty entry
  If GetFileSize64(SourcePath) = 0 Then
    StreamFileToDisk = True
    Exit Function
  End If

  Dim hFile As LongPtr
  hFile = apiCreateFileW(StrPtr(SourcePath), GENERIC_READ, FILE_SHARE_READ, 0, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, 0)
  If hFile = INVALID_HANDLE_VALUE Then
    SetError "[StreamFileToDisk] Cannot open " & SourcePath
    Exit Function
  End If

  Dim buf(0 To STREAM_CHUNK_SIZE - 1) As Byte
  Dim bytesRead As Long, w As LongPtr

  Do
    If apiReadFile(hFile, buf(0), STREAM_CHUNK_SIZE, bytesRead, 0) = 0 Then Exit Do
    If bytesRead = 0 Then Exit Do
    w = archive_write_data(m_hWrite, VarPtr(buf(0)), bytesRead)
    If w < 0 Then
      SetError "[StreamFileToDisk] Write failed: " & SourcePath
      apiCloseHandle hFile
      Exit Function
    End If
  Loop

  apiCloseHandle hFile
  StreamFileToDisk = True
End Function

Private Function DetectTypeFromPath(ByVal filePath As String) As arcType
  
  Dim ext As String
  ext = VBA.LCase$(filePath)
  If VBA.Right$(ext, 7) = ".tar.gz" Or VBA.Right$(ext, 4) = ".tgz" Then
    DetectTypeFromPath = atTarGz
  ElseIf VBA.Right$(ext, 8) = ".tar.bz2" Or VBA.Right$(ext, 4) = ".tbz" Then
    DetectTypeFromPath = atTarBz2
  ElseIf VBA.Right$(ext, 7) = ".tar.xz" Then
    DetectTypeFromPath = atTarXz
  ElseIf VBA.Right$(ext, 8) = ".tar.zst" Then
    DetectTypeFromPath = atTarZst
  ElseIf VBA.Right$(ext, 4) = ".tar" Then
    DetectTypeFromPath = atTar
  ElseIf VBA.Right$(ext, 4) = ".zip" Then
    DetectTypeFromPath = atZip
  ElseIf VBA.Right$(ext, 3) = ".7z" Then
    DetectTypeFromPath = at7Zip
  ElseIf VBA.Right$(ext, 4) = ".xar" Then
    DetectTypeFromPath = atXar
  ElseIf VBA.Right$(ext, 4) = ".iso" Then
    DetectTypeFromPath = atIso
  ElseIf VBA.Right$(ext, 4) = ".cab" Then
    DetectTypeFromPath = atCab
  ElseIf VBA.Right$(ext, 5) = ".cpio" Then
    DetectTypeFromPath = atCpio
  Else
    DetectTypeFromPath = atZip
  End If
End Function

Private Function FormatCodeToArcType(ByVal code As Long) As arcType
  ' Maps a libarchive format code (from archive_format()) to ArcType.
  ' The top three bytes identify the format family; the low byte is a sub-variant.
  ' Returns atAuto if the code is not recognised   caller should fall back to
  ' extension-based detection.

  Select Case (code And &HFFFF00)
  Case &H50000:   FormatCodeToArcType = atZip
  Case &H900000:  FormatCodeToArcType = at7Zip
  Case &H30000:   FormatCodeToArcType = atTar
  Case &H60000:   FormatCodeToArcType = atCpio
  Case &HB0000:   FormatCodeToArcType = atXar
  Case &H160000:  FormatCodeToArcType = atRar
  Case &H180000:  FormatCodeToArcType = atRar5
  Case &H230000:  FormatCodeToArcType = atIso
  Case &H70000:   FormatCodeToArcType = atCab
  Case Else:      FormatCodeToArcType = atAuto
  End Select
End Function

Private Function ArchiveTypeName(ByVal TargetArchiveType As arcType) As String
  Select Case TargetArchiveType
    Case atZip:    ArchiveTypeName = "ZIP"
    Case at7Zip:   ArchiveTypeName = "7-Zip"
    Case atTar:    ArchiveTypeName = "TAR"
    Case atTarGz:  ArchiveTypeName = "TAR+GZ"
    Case atTarBz2: ArchiveTypeName = "TAR+BZ2"
    Case atTarXz:  ArchiveTypeName = "TAR+XZ"
    Case atTarZst: ArchiveTypeName = "TAR+ZST"
    Case atTarPax: ArchiveTypeName = "TAR+PAX"
    Case atTarPaxRestricted: ArchiveTypeName = "TAR+PAX (restricted)"
    Case atTarGnu: ArchiveTypeName = "TAR+GNU"
    Case atCpio:   ArchiveTypeName = "CPIO"
    Case atXar:    ArchiveTypeName = "XAR"
    Case atIso:    ArchiveTypeName = "ISO"
    Case atCab:    ArchiveTypeName = "CAB"
    Case atRar:    ArchiveTypeName = "RAR"
    Case atRar5:   ArchiveTypeName = "RAR5"
    Case Else:     ArchiveTypeName = "Unknown"
  End Select
End Function

Private Sub SetWriteOption(ByVal WriteOption As String)
  Dim b() As Byte
  b = ToUtf8Z(WriteOption)
  If archive_write_set_options(m_hWrite, VarPtr(b(0))) <> ARCHIVE_OK Then
    LogMessage logWarning, "[SetWriteOption] archive_write_set_options failed for: " & WriteOption
  End If
End Sub

Private Function EnsureArchiveInt() As Boolean
  If m_ArchiveIntChecked Then
    EnsureArchiveInt = m_ArchiveIntAvailable
    Exit Function
  End If
  m_ArchiveIntChecked = True
  Dim h As LongPtr
  h = LoadLibraryW(StrPtr("archiveint.dll"))
  If h <> 0 Then
    m_ArchiveIntAvailable = True
    FreeLibrary h
  Else
    m_ArchiveIntAvailable = False
    SetError "[EnsureArchiveInt] archiveint.dll not found."
  End If
  EnsureArchiveInt = m_ArchiveIntAvailable
End Function

Private Function IsRootedPath(ByVal path As String) As Boolean
  ' Returns True if path is fully qualified (i.e. has a drive letter (C:\))
  ' or is a UNC path (\\server\share). Bare names and relative paths return False
  ' and are safe to treat as virtual folder creation requests inside the archive.
  If Len(path) >= 3 Then
    If VBA.Mid$(path, 2, 2) = ":\" Or VBA.Mid$(path, 2, 2) = ":/" Then
      IsRootedPath = True
      Exit Function
    End If
  End If
  If VBA.Left$(path, 2) = "\\" Or VBA.Left$(path, 2) = "//" Then
    IsRootedPath = True
  End If
End Function

Private Sub AddFileEntry(ByVal DiskPath As String, ByVal DestName As String)
  ' Resolves the destination name for a single file and enqueues it.
  ' Large files are marked IsStreamed so they are read in chunks at save time.
  ' Resolve the archive entry name
  Dim entryName As String
  If Len(DestName) = 0 Then
    ' No destination: use bare filename at root
    entryName = FileNameFromPath(DiskPath)
  ElseIf VBA.Right$(DestName, 1) = "/" Or VBA.Right$(DestName, 1) = "\" Then
    ' Destination is a folder prefix: append the bare filename
    entryName = NormaliseEntryName(DestName) & FileNameFromPath(DiskPath)
  Else
    ' Destination is the full entry name
    entryName = NormaliseEntryName(DestName)
  End If

  If Len(entryName) = 0 Then
    LogMessage logWarning, "AddFileEntry: could not resolve entry name for " & DiskPath
    AppendReport "FAILED : " & DiskPath & " - could not resolve entry name"
    Exit Sub
  End If

  ' Optionally skip already-compressed file types
  If m_SkipCompressedTypes Then
    If m_SkipCompressedTypes And IsCompressedFileType(entryName) Then
      LogMessage logDebug, "Will store without re-compressing (already compressed type): " & entryName
    End If
  End If

  ' Decide streaming vs buffering based on file size
  Dim fsize As LongLong, streamed As Boolean
  fsize = GetFileSize64(DiskPath)
  streamed = (fsize > STREAM_CHUNK_SIZE * 8)  ' > 512 KB
  Dim e As QueueEntry
  e.name = entryName
  e.SourcePath = DiskPath
  e.isFolder = False
  e.IsStreamed = streamed
  e.ModifiedDate = FileModifiedDate(DiskPath)
  e.FileSize = fsize

  AppendQueue e
  AppendReport "OK     : " & entryName
  LogMessage logDebug, "Queued: " & entryName & " (" & DiskPath & ")"
End Sub

Private Sub AddFolderRecursive(ByVal folderPath As String, ByVal DestPrefix As String)
  ' Recursively enqueues all files under FolderPath.
  ' The folder entry itself is also queued so the structure is preserved.
  ' DestPrefix controls where in the archive the contents land.

  Dim cleanFolder As String, archivePrefix As String
  cleanFolder = RemoveTrailingSlash(folderPath)
  If Len(DestPrefix) > 0 Then
    archivePrefix = NormaliseEntryName(RemoveTrailingSlash(DestPrefix)) & "/"
  Else
  ' Default: use the folder's own name as the top-level prefix
    archivePrefix = FileNameFromPath(cleanFolder) & "/"
  End If

  ' Queue the folder entry itself
  QueueFolder archivePrefix

  ' Enumerate contents
  Dim fd As WIN32_FIND_DATA
  Dim hFind As LongPtr
  Dim searchPath As String: searchPath = cleanFolder & "\*"

  hFind = apiFindFirstFileW(StrPtr(searchPath), fd)
  If hFind = INVALID_HANDLE_VALUE Then
    LogMessage logWarning, "AddFolderRecursive: cannot enumerate " & folderPath
    Exit Sub
  End If

  Do
    Dim itemName As String
    itemName = PtrToStringW(VarPtr(fd.cFileName(0)))

    If itemName <> "." And itemName <> ".." And Len(itemName) > 0 Then
      Dim itemPath As String: itemPath = cleanFolder & "\" & itemName

      If (fd.dwFileAttributes And FILE_ATTRIBUTE_DIRECTORY) <> 0 Then
        ' Recurse into subfolder
        AddFolderRecursive itemPath, archivePrefix & itemName
      Else
        ' Queue file
        AddFileEntry itemPath, archivePrefix & itemName
      End If
    End If
  Loop While apiFindNextFileW(hFind, fd) <> 0

  apiFindClose hFind
End Sub

Private Sub QueueBytes(ByVal entryName As String, ByRef data() As Byte)
  ' Enqueues a raw byte array under the given entry name.
  Dim e As QueueEntry
  e.name = entryName
  e.isFolder = False
  e.IsStreamed = False
  e.ModifiedDate = Now
  If IsByteArrayUsable(data) Then
    ReDim e.data(LBound(data) To UBound(data))
    apiCopyMemory VarPtr(e.data(LBound(e.data))), VarPtr(data(LBound(data))), UBound(data) - LBound(data) + 1
  Else
    ReDim e.data(0)
  End If
  AppendQueue e
  AppendReport "OK     : " & entryName & " (bytes)"
  LogMessage logDebug, "Queued bytes: " & entryName
End Sub

Private Sub QueueFolder(ByVal entryName As String)
  ' Enqueues a folder entry (zero-size directory marker).
  ' O(1) duplicate check via hash set
  If Not m_FolderIndex Is Nothing Then
    If m_FolderIndex.Exists(entryName) Then Exit Sub
  End If
  Dim e As QueueEntry
  e.name = entryName
  e.isFolder = True
  e.ModifiedDate = Now
  AppendQueue e
  If Not m_FolderIndex Is Nothing Then m_FolderIndex.Add entryName, True
  LogMessage logDebug, "Queued folder: " & entryName
End Sub

Private Sub AppendQueue(ByRef e As QueueEntry)
  ' Appends a QueueEntry to m_Queue(), applying the ConflictMode policy if a
  ' file entry with the same Name already exists in the queue.
  ' Folder entries bypass conflict checking   QueueFolder already deduplicates,
  ' and duplicate folder markers in a ZIP are harmless.
  If Not e.isFolder Then
    Dim conflictIdx As Long
    conflictIdx = FindQueueEntry(e.name)
    If conflictIdx >= 0 Then
      Select Case m_ConflictMode
      Case acmReject
        Dim rejectMsg As String
        rejectMsg = "CONFLICT: " & e.name & " already queued - skipped (acmReject)"
        LogMessage logWarning, rejectMsg
        AppendReport rejectMsg
        Exit Sub
      Case acmOverwrite
        LogMessage logDebug, "CONFLICT: " & e.name & " replaced (acmOverwrite)"
        m_Queue(conflictIdx) = e
        Exit Sub          ' already in the array; count unchanged
      Case acmRename
        e.name = UniqueEntryName(e.name)
        LogMessage logDebug, "CONFLICT: renamed to " & e.name & " (acmRename)"
        ' fall through to append with the new name
      End Select
    End If
  End If
  ' Grow array and append
  If m_QueueCount = 0 Then
    ReDim m_Queue(0 To 0)
  ElseIf m_QueueCount > UBound(m_Queue) Then
    ReDim Preserve m_Queue(0 To m_QueueCount + 63)
  End If
  m_Queue(m_QueueCount) = e
  m_QueueCount = m_QueueCount + 1
End Sub

Private Function FindQueueEntry(ByVal entryName As String) As Long
  ' Returns the index of the first non-folder queue entry whose Name matches
  ' entryName (case-insensitive). Returns -1 if not found.
  
  FindQueueEntry = -1
  Dim i As Long
  For i = 0 To m_QueueCount - 1
    If Not m_Queue(i).isFolder Then
      If StrComp(m_Queue(i).name, entryName, vbTextCompare) = 0 Then
        FindQueueEntry = i
        Exit Function
      End If
    End If
  Next
End Function

Private Function UniqueEntryName(ByVal BaseName As String) As String
  ' Returns a name not already present in the queue by appending (2), (3) etc.
  ' before the extension. Strips any existing "(n)" suffix first so repeated
  ' renames do not produce "alpha (2) (2).txt".
  ' e.g. "docs/alpha.txt" -> "docs/alpha (2).txt" -> "docs/alpha (3).txt"

  ' Split at the last dot that falls within the filename component
  Dim slashPos As Long: slashPos = InStrRev(BaseName, "/")
  Dim dotPos   As Long: dotPos = InStrRev(BaseName, ".")
  Dim stem     As String
  Dim ext      As String
  If dotPos > slashPos Then
    stem = VBA.Left$(BaseName, dotPos - 1)
    ext = VBA.Mid$(BaseName, dotPos)        ' includes the leading dot
  Else
    stem = BaseName
    ext = ""
  End If
  ' Strip any existing " (n)" suffix so repeated calls do not double-suffix
  Dim parenPos As Long: parenPos = InStrRev(stem, " (")
  If parenPos > 0 Then
    If VBA.Mid$(stem, parenPos) Like " ([0-9]*)" Then
      stem = VBA.Left$(stem, parenPos - 1)
    End If
  End If
  ' Try (2), (3) ... until we find a name not already in the queue
  Dim n         As Long: n = 2
  Dim candidate As String
  Do
    candidate = stem & " (" & n & ")" & ext
    If FindQueueEntry(candidate) < 0 Then
      UniqueEntryName = candidate
      Exit Function
    End If
    n = n + 1
    If n > 9999 Then
      ' Pathological fallback
      UniqueEntryName = stem & " (" & Format(Now, "hhmmss") & ")" & ext
      Exit Function
    End If
  Loop
End Function

Private Function NormaliseEntryName(ByVal s As String) As String
  ' Normalise backslashes to forward slashes and strip leading slash
  s = VBA.Replace(s, "\", "/")
  Do While VBA.Left$(s, 1) = "/"
    s = VBA.Mid$(s, 2)
  Loop
  NormaliseEntryName = s
End Function

Private Function RemoveTrailingSlash(ByVal s As String) As String
  ' Strip trailing slash (for folder path normalisation)
  Do While Len(s) > 0 And (VBA.Right$(s, 1) = "/" Or VBA.Right$(s, 1) = "\")
    s = VBA.Left$(s, Len(s) - 1)
  Loop
  RemoveTrailingSlash = s
End Function

Private Function FileNameFromPath(ByVal fullPath As String) As String
  ' Extract bare filename from a full path
  Dim i As Long
  For i = Len(fullPath) To 1 Step -1
    Dim c As String: c = VBA.Mid$(fullPath, i, 1)
    If c = "\" Or c = "/" Then
      FileNameFromPath = VBA.Mid$(fullPath, i + 1)
      Exit Function
    End If
  Next
  FileNameFromPath = fullPath
End Function

Private Function IsCompressedFileType(ByVal name As String) As Boolean
  ' Returns True for file types that are already compressed and benefit little from a second compression pass
  Dim dotPos As Long
  dotPos = InStrRev(name, ".")
  If dotPos = 0 Then Exit Function
  Select Case VBA.LCase$(VBA.Mid$(name, dotPos))
  Case ".zip", ".7z", ".gz", ".rar", ".cab", ".iso", ".xz", ".bz", ".bz2", _
       ".tar", ".tgz", ".jpg", ".mp4", ".mp3", ".png", ".mov", ".aac", ".docx", _
       ".xlsx", ".pptx", ".epub", ".docm", ".xlsm", ".pptm", ".dotm", ".xlam", ".xltm"
    IsCompressedFileType = True
  End Select
End Function

Private Sub AppendReport(ByVal line As String)
  ' Append a line to the operation report
  If Len(m_OperationReport) > 0 Then
    m_OperationReport = m_OperationReport & vbCrLf & line
  Else
    m_OperationReport = line
  End If
End Sub

Public Function Extract(ByVal target As String, _
                        Optional ByVal OutputPath As String = "", _
                        Optional ByVal PassPhrase As String = "") As Variant
                        
  ClearError
  If Not AssertMode(arcModeRead, "Extract") Then
    Extract = IIf(Len(OutputPath) > 0, False, Empty)
    Exit Function
  End If

  ' Apply call-site passphrase if supplied
  Dim effectivePass As String
  effectivePass = IIf(Len(PassPhrase) > 0, PassPhrase, m_Passphrase)

  ' Reopen from the beginning so we can seek to the target entry
  If Not ReopenForRead(effectivePass) Then
    Extract = IIf(Len(OutputPath) > 0, False, Empty)
    Exit Function
  End If

  ' Scan forward to the named entry
  Dim normalTarget As String, found As Boolean
  normalTarget = NormaliseEntryName(target)

  Do While archive_read_next_header(m_hRead, m_hEntry) = ARCHIVE_OK
    Dim entryName As String
    entryName = NormaliseEntryName(PtrToStringW(archive_entry_pathname_w(m_hEntry)))

    If StrComp(entryName, normalTarget, vbTextCompare) = 0 Then
      found = True
      Exit Do
    End If
  Loop

  If Not found Then
    SetError "[Extract] Entry not found: " & target
    Extract = IIf(Len(OutputPath) > 0, False, Empty)
    Exit Function
  End If

  ' Dispatch based on whether a path was supplied
  If Len(OutputPath) > 0 Then
    Extract = ExtractEntryToDisk(OutputPath)
  Else
    Extract = ExtractEntryToBytes()
  End If
End Function

Public Function ExtractAll(ByVal outputFolder As String, _
                           Optional ByVal PassPhrase As String = "") As Boolean
  
  ClearError
  If Not AssertMode(arcModeRead, "ExtractAll") Then Exit Function
  Dim effectivePass As String
  effectivePass = IIf(Len(PassPhrase) > 0, PassPhrase, m_Passphrase)
  If Not ReopenForRead(effectivePass) Then Exit Function
  Dim outRoot As String
  outRoot = RemoveTrailingSlash(outputFolder)
  If Not EnsureDirExists(outRoot) Then
    SetError "[ExtractAll] Cannot create output folder: " & outputFolder
    Exit Function
  End If

  Dim ok         As Boolean: ok = True
  Dim tStart     As Double:  tStart = Timer
  Dim entryIndex As Long
  Dim posUncomp  As LongLong
  Dim pctDone    As Long
  Dim totalCount As Long
  totalCount = m_FileCount + m_FolderCount   ' for fallback progress; 0 if not yet scanned

  RaiseEvent ProgressEvent("Extracting...", 0)

  Do While archive_read_next_header(m_hRead, m_hEntry) = ARCHIVE_OK

    entryIndex = entryIndex + 1
    posUncomp = archive_position_uncompressed(m_hRead)
    If m_TotalUncompressedSize > 0 Then
      pctDone = CLng(posUncomp / (m_TotalUncompressedSize / 100))
      If pctDone > 100 Then pctDone = 100
    ElseIf totalCount > 0 Then
      pctDone = CLng(entryIndex / totalCount * 100)
      If pctDone > 100 Then pctDone = 100
    End If

    Dim entryName As String
    entryName = NormaliseEntryName(PtrToStringW(archive_entry_pathname_w(m_hEntry)))

    RaiseEvent ProgressEvent("Extracting: " & entryName, pctDone)

    Dim isDir As Boolean
    isDir = ((archive_entry_filetype(m_hEntry) And AE_IFDIR) <> 0) Or (VBA.Right$(entryName, 1) = "/")

    If isDir Then
      Dim dirPath As String
      dirPath = outRoot & "\" & VBA.Replace(entryName, "/", "\")
      EnsureDirExists dirPath
    Else
      Dim destPath As String
      destPath = outRoot & "\" & VBA.Replace(entryName, "/", "\")

      If Not EnsureParentDirOfFile(destPath) Then
        LogMessage logWarning, "ExtractAll: could not create folder for " & destPath
        AppendReport "FAILED : " & entryName & " - could not create parent folder"
        ok = False
      ElseIf Not ExtractCurrentEntryToFile(destPath) Then
        AppendReport "FAILED : " & entryName & " - " & m_LastError
        ok = False
      Else
        AppendReport "OK     : " & entryName
        LogMessage logDebug, "Extracted: " & entryName
      End If
    End If

  Loop

  m_LastOperationTime = Timer - tStart
  RaiseEvent ProgressEvent("Done", 100)
  LogMessage logInfo, "ExtractAll completed in " & Format(m_LastOperationTime, "0.000") & "s"
  ExtractAll = ok
End Function
Private Function ExtractEntryToBytes() As Variant
  ' Reads the current entry from the open libarchive handle into a Byte array.
  ' Returns the array as a Variant, or Empty on failure.

  Dim entrySize As LongLong
  entrySize = archive_entry_size(m_hEntry)

  Dim buf() As Byte, totalRead As LongLong

  If entrySize > 0 Then
    ReDim buf(0 To CLng(entrySize) - 1)
    Dim p As LongPtr, sz As LongPtr, off As LongLong

    Do While archive_read_data_block(m_hRead, p, sz, off) = ARCHIVE_OK
      Dim needed As LongLong: needed = off + CLng(sz)
      If needed > UBound(buf) + 1 Then
        ReDim Preserve buf(0 To CLng(needed) - 1)
      End If
      apiCopyMemory VarPtr(buf(0)) + off, p, CLng(sz)
      totalRead = needed
    Loop
  Else
    ' Unknown size: accumulate blocks
    ReDim buf(0 To 65535)
    Dim p2 As LongPtr, sz2 As LongPtr, off2 As LongLong

    Do While archive_read_data_block(m_hRead, p2, sz2, off2) = ARCHIVE_OK
      Dim needed2 As LongLong: needed2 = off2 + CLng(sz2)
      If needed2 > UBound(buf) + 1 Then
        ReDim Preserve buf(0 To CLng(needed2 * 2) - 1)
      End If
      apiCopyMemory VarPtr(buf(0)) + off2, p2, CLng(sz2)
      totalRead = needed2
    Loop
  End If

  If totalRead = 0 Then
    ' Zero bytes from a non-empty entry almost always means wrong passphrase
    If archive_entry_size(m_hEntry) > 0 Then
      SetError "[Extract] No data returned = wrong passphrase or corrupt entry"
    End If
    ExtractEntryToBytes = Empty
    Exit Function
  End If

  ReDim Preserve buf(0 To CLng(totalRead) - 1)
  ExtractEntryToBytes = buf
End Function

Private Function ExtractEntryToDisk(ByVal OutputPath As String) As Boolean
  ' Extracts the current entry from the open libarchive handle to a file on disk.
  ' Returns True on success, False on failure.
  OutputPath = VBA.Replace(OutputPath, "/", "\")
  If Not EnsureParentDirOfFile(OutputPath) Then
    SetError "[ExtractEntryToDisk] Cannot create parent folder(s) for " & OutputPath
    Exit Function
  End If
  ExtractEntryToDisk = ExtractCurrentEntryToFile(OutputPath)
End Function

Private Function ExtractCurrentEntryToFile(ByVal filePath As String) As Boolean
  ' Reads data blocks from the current libarchive entry and writes them to the specified file path.
  Dim hFile As LongPtr
  hFile = apiCreateFileW(StrPtr(filePath), GENERIC_WRITE, 0, 0, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, 0)
  If hFile = INVALID_HANDLE_VALUE Then
    SetError "[ExtractCurrentEntryToFile] Cannot create " & filePath
    Exit Function
  End If

  Dim p As LongPtr, sz As LongPtr, off As LongLong, chunk() As Byte, written As Long

  Do While archive_read_data_block(m_hRead, p, sz, off) = ARCHIVE_OK
    Dim blockLen As Long: blockLen = CLng(sz)
    If blockLen = 0 Then GoTo NextBlock

    ReDim chunk(0 To blockLen - 1)
    apiCopyMemory VarPtr(chunk(0)), p, blockLen

    If apiWriteFile(hFile, chunk(0), blockLen, written, 0) = 0 Or written <> blockLen Then
      SetError "[ExtractCurrentEntryToFile] Write failed for " & filePath
      apiCloseHandle hFile
      Exit Function
    End If
NextBlock:
  Loop

  apiCloseHandle hFile
  ExtractCurrentEntryToFile = True
End Function

Private Function ReopenForRead(ByVal PassPhrase As String) As Boolean
  ' Closes and re-opens the archive from m_SourceFile so iteration can restart
  ' from the beginning. Required because libarchive is forward-only.

  ' Close existing handle
  If m_hRead <> 0 Then
    archive_read_close m_hRead
    archive_read_free m_hRead
    m_hRead = 0
    m_hEntry = 0
  End If

  m_hRead = archive_read_new()
  If m_hRead = 0 Then SetError "[ReopenForRead] archive_read_new failed": Exit Function

  archive_read_support_format_all m_hRead
  archive_read_support_filter_all m_hRead

  ' Supply passphrase if we have one
  If Len(PassPhrase) > 0 Then
    Dim pwd() As Byte: pwd = ToUtf8Z(PassPhrase)
    archive_read_add_passphrase m_hRead, VarPtr(pwd(0))
  End If

  Dim UTF8() As Byte
  UTF8 = ToUtf8Z(m_SourceFile)
  If archive_read_open_filename(m_hRead, VarPtr(UTF8(0)), 65536) <> ARCHIVE_OK Then
    SetError "[ReopenForRead] archive_read_open_filename failed"
    archive_read_free m_hRead
    m_hRead = 0
    Exit Function
  End If

  ReopenForRead = True
End Function

Private Function EnsureDirExists(ByVal dirPath As String) As Boolean
  dirPath = RemoveTrailingSlash(dirPath)
  If Len(dirPath) = 0 Then EnsureDirExists = True: Exit Function
  If FolderExists(dirPath) Then EnsureDirExists = True: Exit Function

  ' Recurse upward first, but stop before drive root ("C:\")
  Dim slashPos As Long
  slashPos = InStrRev(dirPath, "\")
  If slashPos > 3 Then
    Dim parent As String
    parent = VBA.Left$(dirPath, slashPos - 1)
    If Not FolderExists(parent) Then
      If Not EnsureDirExists(parent) Then Exit Function
    End If
  End If

  EnsureDirExists = (apiCreateDirectoryW(StrPtr(dirPath), 0) <> 0) Or FolderExists(dirPath)
End Function

Private Function EnsureParentDirOfFile(ByVal filePath As String) As Boolean
  Dim slashPos As Long
  slashPos = InStrRev(filePath, "\")
  If slashPos = 0 Then slashPos = InStrRev(filePath, "/")
  If slashPos <= 0 Then EnsureParentDirOfFile = True: Exit Function
  EnsureParentDirOfFile = EnsureDirExists(VBA.Left$(filePath, slashPos - 1))
End Function

Public Function Dir(Optional ByVal pattern As String = "*") As Variant
  ' Dir([pattern]) -> Variant (Array of Dictionary, or Empty)
  '  Keys: "Name" (String), "Size" (LongLong), "IsFolder" (Boolean), "Modified" (Date)
  '  Wildcards: * and ? supported. Examples: "*.pdf", "docs/*", "*/"
  ' In write mode, reflect the pending queue, in read mode, ensure the scan cache is populated
  ClearError

  If m_Mode = arcModeNone Then
    SetError "[Dir] No archive is open."
    Dir = Empty
    Exit Function
  End If
  
  If m_Mode = arcModeWrite Then
    Dir = DirFromQueue(pattern)
    Exit Function
  End If
  
  If Not m_Scanned Then EnsureScanned

  If m_ScanCount = 0 Then
    Dir = Empty
    Exit Function
  End If

  Dim matches()  As Object    ' Scripting.Dictionary - for now...
  Dim matchCount As Long

  Dim i As Long
  For i = 0 To m_ScanCount - 1
    If MatchesPattern(m_ScanEntries(i).name, pattern) Then
      If matchCount = 0 Then
        ReDim matches(0 To 0)
      ElseIf matchCount > UBound(matches) Then
        ReDim Preserve matches(0 To matchCount + 63)
      End If
      Set matches(matchCount) = EntryToDict(m_ScanEntries(i))
      matchCount = matchCount + 1
    End If
  Next

  If matchCount = 0 Then
    Dir = Empty
    Exit Function
  End If

  ReDim Preserve matches(0 To matchCount - 1)
  Dir = matches
End Function

Private Sub EnsureScanned()
  ' Iterates the archive once to populate m_ScanEntries().
  ' The archive handle is reopened so the cursor starts from the beginning,
  ' then reopened again afterwards so the caller can still iterate if needed.
  If m_Scanned Then Exit Sub
  m_TotalUncompressedSize = 0
  m_TotalCompressedSize = 0
  If m_Mode <> arcModeRead Then Exit Sub

  LogMessage logDebug, "Scanning archive for aggregate metadata..."

  If Not ReopenForRead(m_Passphrase) Then
    LogMessage logWarning, "EnsureScanned: could not reopen archive."
    Exit Sub
  End If

  m_FileCount = 0
  m_FolderCount = 0
  m_IsEncrypted = False
  m_ScanCount = 0
  Erase m_ScanEntries

  Do While archive_read_next_header(m_hRead, m_hEntry) = ARCHIVE_OK
    Dim se As ScannedEntry
    se.name = NormaliseEntryName(PtrToStringW(archive_entry_pathname_w(m_hEntry)))
    se.isFolder = ((archive_entry_filetype(m_hEntry) And AE_IFDIR) <> 0) Or (VBA.Right$(se.name, 1) = "/")
    se.UncompressedSize = archive_entry_size(m_hEntry)
    se.ModifiedUnix = archive_entry_mtime(m_hEntry)

    ' Detect encryption from the first non-folder entry
    If Not m_IsEncrypted And Not se.isFolder Then
      m_IsEncrypted = (archive_entry_is_encrypted(m_hEntry) <> 0)
    End If

    ' Detect encryption method from format name string
    If m_IsEncrypted Then
      Dim fmtName As String
      fmtName = VBA.LCase$(PtrToStringA(archive_format_name(m_hRead)))
      ' Options include
      ' - zip 2.0 (uncompressed)
      ' - zip 2.0 (deflation)

      If InStr(fmtName, "winzip") > 0 Or InStr(fmtName, "aes") > 0 Then
        m_DetectedEncryption = aeAes256   ' strength not distinguishable here
      ElseIf InStr(fmtName, "uncompressed") = 0 Then
        m_DetectedEncryption = aeZipCrypto
      Else
        m_DetectedEncryption = aeUnknown
      End If
    Else
      m_DetectedEncryption = aeNone
    End If

    If m_ScanCount = 0 Then
      ReDim m_ScanEntries(0 To 63)
    ElseIf m_ScanCount > UBound(m_ScanEntries) Then
      ReDim Preserve m_ScanEntries(0 To m_ScanCount + 63)
    End If
    m_ScanEntries(m_ScanCount) = se
    m_ScanCount = m_ScanCount + 1

    If se.isFolder Then
      m_FolderCount = m_FolderCount + 1
    Else
      m_FileCount = m_FileCount + 1
    End If

    If Not se.isFolder Then
      m_TotalUncompressedSize = m_TotalUncompressedSize + se.UncompressedSize
    End If
  Loop

  If m_ScanCount > 0 Then
    ReDim Preserve m_ScanEntries(0 To m_ScanCount - 1)
  End If

  ' Total compressed size = the archive's footprint on disk.
  ' Per-entry differencing of archive_position_compressed() would be more
  ' granular but includes local-header overhead; the on-disk size is the
  ' honest "how big is this archive" answer and is always available.
  Dim fsz As LongLong
  fsz = GetFileSize64(m_SourceFile)
  If fsz >= 0 Then m_TotalCompressedSize = fsz

  m_Scanned = True
  LogMessage logDebug, "Scan complete: " & m_FileCount & " files, " & m_FolderCount & " folders."

  ' Reopen so the caller can still do sequential reads if desired
  ReopenForRead m_Passphrase
End Sub


Private Function DirFromQueue(ByVal pattern As String) As Variant
  ' In write mode, Dir reflects the pending queue rather than an on-disk archive.
  If m_QueueCount = 0 Then
    DirFromQueue = Empty
    Exit Function
  End If

  Dim matches()  As Object
  Dim matchCount As Long

  Dim i As Long
  For i = 0 To m_QueueCount - 1
    If MatchesPattern(m_Queue(i).name, pattern) Then
      If matchCount = 0 Then
        ReDim matches(0 To 0)
      ElseIf matchCount > UBound(matches) Then
        ReDim Preserve matches(0 To matchCount + 63)
      End If

      Dim d As Object
      Set d = CreateObject("Scripting.Dictionary")
      d("Name") = m_Queue(i).name
      d("Size") = CLngLng(0)          ' size not yet known for queued items
      d("IsFolder") = m_Queue(i).isFolder
      d("Modified") = m_Queue(i).ModifiedDate

      Set matches(matchCount) = d
      matchCount = matchCount + 1
    End If
  Next

  If matchCount = 0 Then
    DirFromQueue = Empty
    Exit Function
  End If

  ReDim Preserve matches(0 To matchCount - 1)
  DirFromQueue = matches
End Function

Private Function MatchesPattern(ByVal Subject As String, ByVal pattern As String) As Boolean
  ' Trivial cases
  If pattern = "*" Or pattern = "" Then
    MatchesPattern = True
    Exit Function
  End If

  ' Delegate to recursive wildcard match
  MatchesPattern = WildMatch(VBA.LCase$(Subject), VBA.LCase$(pattern), 1, 1)
End Function

Private Function WildMatch(ByVal Subject As String, ByVal pattern As String, ByVal si As Long, ByVal pi As Long) As Boolean
  ' Recursive wildcard matcher supporting * and ?.
  ' si = current position in Subject (1-based)
  ' pi = current position in Pattern (1-based)

  Do
    ' Both exhausted: match
    If si > Len(Subject) And pi > Len(pattern) Then
      WildMatch = True
      Exit Function
    End If

    ' Pattern exhausted but subject remains: no match
    If pi > Len(pattern) Then Exit Function

    Dim pc As String: pc = VBA.Mid$(pattern, pi, 1)

    If pc = "*" Then
    ' Skip consecutive stars
      Do While pi <= Len(pattern) And VBA.Mid$(pattern, pi, 1) = "*"
        pi = pi + 1
      Loop
      ' If star is at the end of pattern: match everything remaining
      If pi > Len(pattern) Then
        WildMatch = True
        Exit Function
      End If
      ' Try matching the rest of the pattern at every position in subject
      Dim k As Long
      For k = si To Len(Subject) + 1
        If WildMatch(Subject, pattern, k, pi) Then
          WildMatch = True
          Exit Function
        End If
      Next
      Exit Function

    ElseIf pc = "?" Then
      ' matches any single character; subject must not be exhausted
      If si > Len(Subject) Then Exit Function
      si = si + 1
      pi = pi + 1

    Else
      ' Literal match required
      If si > Len(Subject) Then Exit Function
      If VBA.Mid$(Subject, si, 1) <> pc Then Exit Function
      si = si + 1
      pi = pi + 1
    End If
  Loop
End Function

Private Function EntryToDict(ByRef se As ScannedEntry) As Object
  ' Converts a ScannedEntry to a Scripting.Dictionary with the public key set.
  Dim d As Object
  Set d = CreateObject("Scripting.Dictionary")

  d("Name") = se.name
  d("Size") = se.UncompressedSize
  d("IsFolder") = se.isFolder
  d("Modified") = UnixToDate(se.ModifiedUnix)

  Set EntryToDict = d
End Function

' -------------------
'  PUBLIC PROPERTIES
' -------------------

Public Property Get ArchiveType() As arcType
  ArchiveType = m_Type
End Property

Public Property Let ArchiveType(ByVal val As arcType)
  If m_Mode <> arcModeWrite Then
    LogMessage logWarning, "ArchiveType can only be set in write mode."
    Exit Property
  End If
  m_Type = val
End Property

Public Property Get Mode() As ArchiveMode
  Mode = m_Mode
End Property

Public Property Get FileCount() As Long
  ' Number of non-folder entries in the opened archive (read only obviously).
  If m_Mode = arcModeRead Then EnsureScanned
  FileCount = m_FileCount
End Property

Public Property Get FolderCount() As Long
  ' Number of folder entries in the opened archive (read only obviously).
  If m_Mode = arcModeRead Then EnsureScanned
  FolderCount = m_FolderCount
End Property

Public Property Get IsEncrypted() As Boolean
  ' IsEncrypted: looks at the first non-folder entry to check the encryption flag.
  ' Works on the (perhaps erroneous?) assumption that if one entry is encrypted, then all are.
  ' Someone will doubtless tell me if I'm wrong on this point.
  If m_Mode = arcModeWrite Then
    IsEncrypted = (m_Encryption <> aeNone) And Len(m_Passphrase) > 0
  ElseIf m_Mode = arcModeRead Then
    If Not m_Scanned Then EnsureScanned
    IsEncrypted = m_IsEncrypted
  End If
End Property

Public Property Let PassPhrase(ByVal val As String)
  m_Passphrase = val
End Property

Public Property Get PassPhrase() As String
  PassPhrase = m_Passphrase
End Property

Public Property Let Encryption(ByVal val As ArchiveEncryption)
  If m_Mode <> arcModeWrite Then
    LogMessage logWarning, "Encryption can only be set in write mode."
    Exit Property
  End If
  ' aeUnknown is a read-mode detection result ("encrypted, method indeterminate")
  ' and is not a valid write-mode setting. Reject it explicitly so a caller
  ' cannot accidentally produce a silently-unencrypted archive by passing it.
  If val < aeNone Or val > aeAes256 Then
    LogMessage logWarning, "[Encryption] Invalid value " & val & " - use aeNone, aeZipCrypto, aeAes128, aeAes192, or aeAes256."
    Exit Property
  End If
  ' AES modes are only meaningful for ZIP
  If val >= aeAes128 And m_Type <> atZip Then
    LogMessage logWarning, "[Encryption] AES encryption is only supported for ZIP archives."
    Exit Property
  End If
  m_Encryption = val
End Property

Public Property Get Encryption() As ArchiveEncryption
  If m_Mode = arcModeWrite Then
    Encryption = m_Encryption
  ElseIf m_Mode = arcModeRead Then
    If Not m_Scanned Then EnsureScanned
    Encryption = m_DetectedEncryption
  End If
End Property

Public Property Get UncompressedSize() As LongLong
  If m_Mode = arcModeRead Then EnsureScanned
  UncompressedSize = m_TotalUncompressedSize
End Property

Public Property Get CompressedSize() As LongLong
  If m_Mode = arcModeRead Then EnsureScanned
  CompressedSize = m_TotalCompressedSize
End Property

Public Property Get CompressionRatio() As Double
  If m_Mode = arcModeRead Then EnsureScanned
  If m_TotalUncompressedSize = 0 Then Exit Property
  CompressionRatio = 1 - (CDbl(m_TotalCompressedSize) / CDbl(m_TotalUncompressedSize))
End Property

' 0 = store only; 1-9 = fastest to best (format-dependent).
' For ZIP/7z/TAR variants, 6 is a sensible default.
Public Property Let CompressionLevel(ByVal val As Long)
  If val < 0 Or val > 9 Then
    LogMessage logWarning, "CompressionLevel must be 0-9."
    Exit Property
  End If
  m_CompressionLevel = val
End Property

Public Property Get CompressionLevel() As Long
  CompressionLevel = m_CompressionLevel
End Property

Public Property Let ConflictMode(ByVal val As ArcConflictMode)
  ' Controls how duplicate entry names are handled during queuing.
  ' acmReject (default): skip and log
  ' acmOverwrite: replace
  ' acmRename: suffix
  If m_Mode <> arcModeWrite Then
    LogMessage logWarning, "ConflictMode can only be set in write mode."
    Exit Property
  End If
  m_ConflictMode = val
End Property

Public Property Get ConflictMode() As ArcConflictMode
  ConflictMode = m_ConflictMode
End Property

Public Property Let SkipCompressedFileTypes(ByVal val As Boolean)
  ' When True, files whose extension implies they are already compressed
  ' (JPEG, MP4, ZIP, DOCX, etc.) are stored without a second compression pass.
  ' You will note that this is what happens with Office OOXML files, for example.
  ' See my PR: https://github.com/cristianbuse/Excel-ZipTools/pull/1
  m_SkipCompressedTypes = val
End Property

Public Property Get SkipCompressedFileTypes() As Boolean
  SkipCompressedFileTypes = m_SkipCompressedTypes
End Property

Public Property Get LastError() As String
  ' Last error message set by any operation.  Cleared at the start of each
  ' public method call via ClearError.
  LastError = m_LastError
End Property

Public Property Get OperationReport() As String
  ' Multiline string summarising per-entry success/failure from the most
  ' recent SaveFile or ExtractAll call.
  OperationReport = m_OperationReport
End Property

Public Property Get LastOperationTime() As Double
  ' Elapsed seconds for the most recent SaveFile / ExtractAll call.
  ' I find it useful - you're welcome to ignore it.
  LastOperationTime = m_LastOperationTime
End Property

Public Property Let LogLevel(ByVal val As ArcLogLevel)
  m_LogLevel = val
End Property

Public Property Get LogLevel() As ArcLogLevel
  LogLevel = m_LogLevel
End Property

Public Property Let ProgressInterval(ByVal val As Long)
  ' Number of entries between Progress raises during write/extract.
  ' 1 = raise on every entry (default); 0 = suppress ProgressEvent events.
  m_ProgressInterval = val
End Property

Public Property Get ProgressInterval() As Long
  ProgressInterval = m_ProgressInterval
End Property

Private Function pvCryptoAesInit(ByRef State As ArchiveCryptoState, ByRef baPass() As Byte, ByRef baSalt() As Byte, ByVal lKeyLen As Long, ByRef nPassVer As Integer) As Boolean
  Dim hResult As Long, lDummy As Long

  If State.hPbkdf2Alg = 0 Then
    hResult = BCryptOpenAlgorithmProvider(State.hPbkdf2Alg, StrPtr(BCRYPT_SHA1_ALGORITHM), StrPtr(MS_PRIMITIVE_PROVIDER), BCRYPT_ALG_HANDLE_HMAC_FLAG)
    If hResult < 0 Then
      SetError "[pvCryptoAesInit] BCryptOpenAlgorithmProvider(PBKDF2) failed: " & Hex$(hResult)
      Exit Function
    End If
  End If

  Dim baDerivedKey() As Byte
  ReDim baDerivedKey(0 To 2 * lKeyLen + 1)

  hResult = BCryptDeriveKeyPBKDF2(State.hPbkdf2Alg, baPass(0), UBound(baPass) + 1, baSalt(0), UBound(baSalt) + 1, CLngLng(PBKDF2_ITERATIONS), baDerivedKey(0), UBound(baDerivedKey) + 1, 0)

  If hResult < 0 Then
    SetError "[pvCryptoAesInit] BCryptDeriveKeyPBKDF2 failed: " & Hex$(hResult)
    Exit Function
  End If

  apiCopyMemory VarPtr(nPassVer), VarPtr(baDerivedKey(2 * lKeyLen)), 2

  If State.hAesAlg = 0 Then
    hResult = BCryptOpenAlgorithmProvider(State.hAesAlg, StrPtr(BCRYPT_AES_ALGORITHM), StrPtr(MS_PRIMITIVE_PROVIDER), 0)
    If hResult < 0 Then
      SetError "[pvCryptoAesInit] BCryptOpenAlgorithmProvider(AES) failed: " & Hex$(hResult)
      Exit Function
    End If

    hResult = BCryptGetProperty(State.hAesAlg, StrPtr(BCRYPT_OBJECT_LENGTH), State.AesKeyObjLen, 4, lDummy, 0)
    If hResult < 0 Then
      SetError "[pvCryptoAesInit] BCryptGetProperty(ObjectLength) failed: " & Hex$(hResult)
      Exit Function
    End If

    hResult = BCryptSetProperty(State.hAesAlg, StrPtr(BCRYPT_CHAINING_MODE), ByVal StrPtr(BCRYPT_CHAIN_MODE_ECB), LenB(BCRYPT_CHAIN_MODE_ECB), 0)
    If hResult < 0 Then
      SetError "[pvCryptoAesInit] BCryptSetProperty(ChainingMode) failed: " & Hex$(hResult)
      Exit Function
    End If
  End If

  If State.hAesKey <> 0 Then
    BCryptDestroyKey State.hAesKey
    State.hAesKey = 0
  End If

  ReDim State.AesKeyObjData(0 To State.AesKeyObjLen - 1)
  hResult = BCryptGenerateSymmetricKey(State.hAesAlg, State.hAesKey, State.AesKeyObjData(0), State.AesKeyObjLen, baDerivedKey(0), lKeyLen, 0)
  If hResult < 0 Then
    SetError "[pvCryptoAesInit] BCryptGenerateSymmetricKey failed: " & Hex$(hResult)
    Exit Function
  End If

  If State.hHmacAlg = 0 Then
    hResult = BCryptOpenAlgorithmProvider(State.hHmacAlg, StrPtr(BCRYPT_SHA1_ALGORITHM), StrPtr(MS_PRIMITIVE_PROVIDER), BCRYPT_ALG_HANDLE_HMAC_FLAG)
    If hResult < 0 Then
      SetError "[pvCryptoAesInit] BCryptOpenAlgorithmProvider(HMAC) failed: " & Hex$(hResult)
      Exit Function
    End If
    BCryptGetProperty State.hHmacAlg, StrPtr(BCRYPT_HASH_LENGTH), State.HmacLen, 4, lDummy, 0
  End If

  If State.hHmacHash <> 0 Then
    BCryptDestroyHash State.hHmacHash
    State.hHmacHash = 0
  End If

  hResult = BCryptCreateHash(State.hHmacAlg, State.hHmacHash, 0, 0, baDerivedKey(lKeyLen), lKeyLen, 0)
  If hResult < 0 Then
    SetError "[pvCryptoAesInit] BCryptCreateHash failed: " & Hex$(hResult)
    Exit Function
  End If

  pvCryptoAesInit = True
End Function

Private Function pvCryptoAesCrypt(ByRef State As ArchiveCryptoState, ByRef baData() As Byte, Optional ByVal offset As Long = 0, Optional ByVal size As Long = -1, Optional ByVal HashBefore As Boolean = False, Optional ByVal HashAfter As Boolean = False) As Boolean
  ' AES-CTR encrypt or decrypt baData() in-place.
  ' HashBefore: feed data into HMAC *before* XOR  (decrypt path)
  ' HashAfter:  feed data into HMAC *after*  XOR  (encrypt path)
  ' Both default False; for normal AES-CTR use without HMAC pass neither.

  Dim lIdx As Long, j As Long, lDummy As Long, hResult As Long, lPadSize As Long

  If size < 0 Then size = UBound(baData) + 1 - offset
  If size = 0 Then pvCryptoAesCrypt = True: Exit Function

  If HashBefore Then
    hResult = BCryptHashData(State.hHmacHash, baData(offset), size, 0)
    If hResult < 0 Then Exit Function
  End If

  Dim bEncrDataInit As Boolean
  On Error Resume Next
  bEncrDataInit = (UBound(State.EncrData) >= LBound(State.EncrData))
  On Error GoTo 0

  For lIdx = offset To offset + size - 1
    If (State.EncrPos And 15) = 0 Then Exit For
    baData(lIdx) = baData(lIdx) Xor State.EncrData(State.EncrPos)
    State.EncrPos = State.EncrPos + 1
  Next

  If lIdx < offset + size Then
    lPadSize = (offset + size - lIdx + 15) And Not 15
    If Not bEncrDataInit Then
      ReDim State.EncrData(0 To lPadSize - 1)
    ElseIf UBound(State.EncrData) + 1 < lPadSize Then
      ReDim State.EncrData(0 To lPadSize - 1)
    End If

    For j = 0 To (lPadSize \ 16) - 1
      Dim bSum As Integer, nIdx As Integer, carry As Integer
      bSum = State.Nonce(0) + 1
      State.Nonce(0) = bSum And &HFF
      If bSum > 255 Then
        carry = 1
        For nIdx = 1 To 15
          bSum = State.Nonce(nIdx) + carry
          State.Nonce(nIdx) = bSum And &HFF
          If State.Nonce(nIdx) <> 0 Then
            carry = 0
            Exit For
          End If
        Next
      End If
      apiCopyMemory VarPtr(State.EncrData(j * 16)), VarPtr(State.Nonce(0)), 16
    Next

    hResult = BCryptEncrypt(State.hAesKey, State.EncrData(0), lPadSize, 0, 0, 0, State.EncrData(0), lPadSize, lDummy, 0)
    If hResult < 0 Then
      SetError "[pvCryptoAesCrypt] BCryptEncrypt failed: " & Hex$(hResult)
      Exit Function
    End If
    
    State.EncrPos = offset + size - lIdx
    For j = 0 To State.EncrPos - 1
      baData(lIdx + j) = baData(lIdx + j) Xor State.EncrData(j)
    Next
  End If

  If HashAfter Then
    hResult = BCryptHashData(State.hHmacHash, baData(offset), size, 0)
    If hResult < 0 Then Exit Function
  End If

  pvCryptoAesCrypt = True
End Function

Private Function pvCryptoAesGetFinalHash(ByRef State As ArchiveCryptoState, ByVal lSize As Long) As Byte()
  Dim baResult() As Byte
  ReDim baResult(0 To State.HmacLen - 1)
  BCryptFinishHash State.hHmacHash, baResult(0), State.HmacLen, 0
  ReDim Preserve baResult(0 To lSize - 1)
  pvCryptoAesGetFinalHash = baResult
End Function

Private Sub pvCryptoTerminate(ByRef State As ArchiveCryptoState)
  If State.hHmacHash <> 0 Then BCryptDestroyHash State.hHmacHash: State.hHmacHash = 0
  If State.hHmacAlg <> 0 Then BCryptCloseAlgorithmProvider State.hHmacAlg, 0: State.hHmacAlg = 0
  If State.hAesKey <> 0 Then BCryptDestroyKey State.hAesKey: State.hAesKey = 0
  If State.hAesAlg <> 0 Then BCryptCloseAlgorithmProvider State.hAesAlg, 0: State.hAesAlg = 0
  If State.hPbkdf2Alg <> 0 Then BCryptCloseAlgorithmProvider State.hPbkdf2Alg, 0: State.hPbkdf2Alg = 0
End Sub

Private Sub pvCryptoGetRandom(ByVal lSize As Long, ByRef baOutput() As Byte)
  ReDim baOutput(0 To lSize - 1)
  RtlGenRandom baOutput(0), lSize
End Sub

Private Function CalculateCRC32(ByRef data() As Byte) As Long
  If Not IsByteArrayUsable(data) Then CalculateCRC32 = 0: Exit Function
  CalculateCRC32 = RtlComputeCrc32(0, data(LBound(data)), UBound(data) - LBound(data) + 1)
End Function

Private Function SaveZip_AES() As Boolean
  ' NB: Archives exceeding 2 GB are not supported. Zip64 is not implemented (yet).
  m_TotalUncompressedSize = 0
  m_TotalCompressedSize = 0

  Dim hFile As LongPtr
  hFile = apiCreateFileW(StrPtr(m_SourceFile), GENERIC_WRITE, 0, 0, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, 0)
  If hFile = INVALID_HANDLE_VALUE Then
    hFile = 0
    SetError "[SaveZip_AES] cannot create output file: " & m_SourceFile
    Exit Function
  End If
  On Error GoTo ErrHandler

  Dim lKeyLen   As Long, lSaltLen As Long, bStrength As Byte

  Select Case m_Encryption
    Case aeAes128
      lKeyLen = AES128_KEY_LEN
      lSaltLen = AES128_SALT_LEN
      bStrength = 1
    Case aeAes192
      lKeyLen = AES192_KEY_LEN
      lSaltLen = AES192_SALT_LEN
      bStrength = 2
    Case aeAes256
      lKeyLen = AES256_KEY_LEN
      lSaltLen = AES256_SALT_LEN
      bStrength = 3
    Case Else
      SetError "[SaveZip_AES] Unexpected encryption mode " & m_Encryption
      GoTo CleanUp
  End Select
  Dim baPass() As Byte
  baPass = ToUtf8Z(m_Passphrase)
  
  ' ToUtf8Z appends a null terminator - strip it for PBKDF2
  Dim passLen As Long
  passLen = UBound(baPass) ' exclude null terminator
  
  Dim fileInfos() As AesFileInfo, currentOffset As Long, i As Long, ok As Boolean
  
  ReDim fileInfos(0 To m_QueueCount - 1)
  ok = True
  RaiseEvent ProgressEvent("Writing AES ZIP...", 0)
  
  For i = 0 To m_QueueCount - 1
    If m_ProgressInterval > 0 And (i Mod m_ProgressInterval) = 0 Then
      RaiseEvent ProgressEvent("Encrypting: " & m_Queue(i).name, CLng((i + 1) / m_QueueCount * 100))
    End If
    fileInfos(i).LocalHeaderOffset = currentOffset
    Dim entryOk As Boolean
    entryOk = WriteAesEntry(hFile, m_Queue(i), fileInfos(i), baPass, passLen, lKeyLen, lSaltLen, bStrength)
    If Not entryOk Then
      AppendReport "FAILED : " & m_Queue(i).name & " - " & m_LastError
      LogMessage logWarning, "SaveZip_AES: entry failed: " & m_Queue(i).name
      ok = False
    Else
      AppendReport "OK     : " & m_Queue(i).name
      ' Add sizes from the populated AesFileInfo struct
      m_TotalUncompressedSize = m_TotalUncompressedSize + CLngLng(fileInfos(i).UncompressedSize)
      m_TotalCompressedSize = m_TotalCompressedSize + CLngLng(fileInfos(i).CompressedSize)
    End If
    ' Advance offset: LFH (30) + UTF-8 name + AES extra field + payload.
    ' Name length must be the UTF-8 byte count (fi.NameLenUtf8) - characters, otherwise non-ASCII
    ' names drift the next entry's LocalHeaderOffset and break strict readers like Windows Explorer.
    currentOffset = currentOffset + 30 + fileInfos(i).NameLenUtf8 + IIf(fileInfos(i).compressionMethod = COMPRESSION_AES, 11, 0) + fileInfos(i).CompressedSize
  Next
  
  ' Central directory
  Dim cdOffset As Long, cdSize As Long
  cdOffset = currentOffset
  
  If Not WriteAesCentralDirectory(hFile, fileInfos, m_QueueCount, cdSize) Then
    SetError "[SaveZip_AES] central directory write failed"
    GoTo CleanUp
  End If
  
  ' End of central directory
  If Not WriteAesEOCD(hFile, m_QueueCount, cdSize, cdOffset) Then
    SetError "[SaveZip_AES] EOCD write failed"
    GoTo CleanUp
  End If
  
  RaiseEvent ProgressEvent("Done", 100)
  SaveZip_AES = ok
  GoTo CleanUp

ErrHandler:
  SetError "[SaveZip_AES] Error - " & Err.Number & " - " & Err.Description
  SaveZip_AES = False

CleanUp:
  If hFile <> 0 Then
    apiCloseHandle hFile
    hFile = 0
  End If
End Function

Private Function WriteAesEntry(ByVal hFile As LongPtr, ByRef e As QueueEntry, ByRef fi As AesFileInfo, ByRef baPass() As Byte, ByVal passLen As Long, ByVal lKeyLen As Long, ByVal lSaltLen As Long, ByVal bStrength As Byte) As Boolean
  ' Processes one queue entry end-to-end: load, compress, encrypt, write LFH.
  ' Populates fi with the metadata needed for the central directory.
  fi.name = e.name
  fi.isFolder = e.isFolder
  fi.ModifiedDate = e.ModifiedDate
  fi.NameLenUtf8 = UBound(ToUtf8(fi.name)) + 1

  ' Folders are zero-size entries and are not encrypted
  If e.isFolder Then
    fi.IsEncrypted = False
    fi.CRC32 = 0
    fi.UncompressedSize = 0
    fi.CompressedSize = 0
    fi.compressionMethod = COMPRESSION_STORE
    Dim emptyA() As Byte, emptyB() As Byte, emptyC() As Byte
    WriteAesEntry = WriteLFH(hFile, fi, emptyA, emptyB, emptyC)
    Exit Function
  End If

  Dim rawData() As Byte
  If Len(e.SourcePath) > 0 Then
    Dim FileSize As LongLong: FileSize = GetFileSize64(e.SourcePath)
    If FileSize < 0 Then
      SetError "[WriteAesEntry] Could not read " & e.SourcePath
      Exit Function
    End If
    If FileSize > 0 Then
      rawData = ReadFileToBytes(e.SourcePath)
      If Not IsByteArrayUsable(rawData) Then
        SetError "[WriteAesEntry] Could not read " & e.SourcePath
        Exit Function
      End If
    End If
  ' fileSize = 0 falls through with uninitialised rawData
  ElseIf IsByteArrayUsable(e.data) Then
    rawData = e.data
  Else
    ReDim rawData(0)
  End If

  ' Zero-byte file = write as stored empty entry with no encryption
  If Not IsByteArrayUsable(rawData) Then
    fi.CRC32 = 0
    fi.UncompressedSize = 0
    fi.CompressedSize = 0
    fi.compressionMethod = COMPRESSION_STORE
    fi.IsEncrypted = False
    Dim emptyAA() As Byte, emptyBB() As Byte, emptyCC() As Byte
    WriteAesEntry = WriteLFH(hFile, fi, emptyAA, emptyBB, emptyCC)
    Exit Function
  End If

  Dim UncompressedSize As Long
  UncompressedSize = UBound(rawData) - LBound(rawData) + 1

  fi.CRC32 = CalculateCRC32(rawData)

  Dim compressedData() As Byte, compressionMethod As Integer, shouldStore As Boolean
  shouldStore = (m_CompressionLevel = 0) Or (m_SkipCompressedTypes And IsCompressedFileType(e.name)) Or (UncompressedSize = 0)

  If shouldStore Then
    compressedData = rawData
    compressionMethod = COMPRESSION_STORE
  Else
    compressedData = Deflate_ArchiveInt(rawData)
    If Not IsByteArrayUsable(compressedData) Then
      ' DEFLATE failed - fall back to store
      LogMessage logWarning, "WriteAesEntry: Deflate_ArchiveInt failed for " & e.name & ", storing."
      compressedData = rawData
      compressionMethod = COMPRESSION_STORE
    Else
      compressionMethod = COMPRESSION_DEFLATE
    End If
  End If

  fi.UncompressedSize = UncompressedSize
  fi.OrigCompressionMethod = compressionMethod

  ' AES encryption route
  Dim baSalt() As Byte, encHeader() As Byte, baMac() As Byte, nPassVer As Integer, aesState As ArchiveCryptoState

  pvCryptoGetRandom lSaltLen, baSalt

  If Not pvCryptoAesInit(aesState, baPass, baSalt, lKeyLen, nPassVer) Then
    SetError "[WriteAesEntry] AES init failed for " & e.name
    Exit Function
  End If

  ' Encryption header = salt + 2-byte PVV
  ReDim encHeader(0 To lSaltLen + 1)
  apiCopyMemory VarPtr(encHeader(0)), VarPtr(baSalt(0)), lSaltLen
  apiCopyMemory VarPtr(encHeader(lSaltLen)), VarPtr(nPassVer), 2

  ' Encrypt in place; hash after XOR (encrypt path: HashBefore=False, HashAfter=True)
  pvCryptoAesCrypt aesState, compressedData, , , False, True
  baMac = pvCryptoAesGetFinalHash(aesState, HMAC_TAG_LEN)
  pvCryptoTerminate aesState

  fi.CRC32 = 0
  fi.compressionMethod = COMPRESSION_AES
  fi.EncryptionStrength = bStrength
  fi.IsEncrypted = True

  ' CompressedSize as stored in headers: enc header (salt + PVV) + ciphertext + MAC
  fi.CompressedSize = (lSaltLen + 2) + (UBound(compressedData) - LBound(compressedData) + 1) + HMAC_TAG_LEN
  WriteAesEntry = WriteLFH(hFile, fi, encHeader, compressedData, baMac)
End Function

Private Function WriteLFH(ByVal hFile As LongPtr, ByRef fi As AesFileInfo, ByRef encHeader() As Byte, ByRef compressedData() As Byte, ByRef baMac() As Byte) As Boolean
  ' Writes: LFH struct (30 bytes) + UTF-8 name + AES extra field (11 bytes if AES) + encHeader + compressedData + baMac
  ' Any of encHeader / compressedData / baMac may be Nothing / empty

  Dim nameUtf8() As Byte, nameLen As Integer
  nameUtf8 = ToUtf8(fi.name)
  nameLen = UBound(nameUtf8) + 1

  Dim extraLen As Integer, baExtra() As Byte
  If fi.compressionMethod = COMPRESSION_AES Then
    extraLen = 11
    baExtra = BuildAesExtraField(fi.EncryptionStrength, fi.OrigCompressionMethod)
  End If

  ' Flags: bit 0 = encrypted, bit 11 = UTF-8 name (set when name holds any
  ' non-ASCII character so readers don't decode the bytes as the local codepage).
  Dim flags As Integer
  flags = 0
  If fi.IsEncrypted Then flags = flags Or &H1
  If fi.NameLenUtf8 <> Len(fi.name) Then flags = flags Or &H800

  ' Version needed: 51 for AES, 20 otherwise
  Dim verNeeded As Integer
  verNeeded = IIf(fi.compressionMethod = COMPRESSION_AES, 51, 20)

  ' LFH fixed header: exactly 30 bytes
  ' Offset  0 : signature (4), 4: version needed (2), 6: flags (2)
  ' Offset  8 : method (2), 10: mod time (2), 12: mod date (2)
  ' Offset 14 : CRC32 (4), 18: compressed size (4), 22: uncompressed size (4)
  ' Offset 26 : name length (2), 28: extra length (2)
  Dim buf(0 To 29) As Byte
  WriteLong buf, 0, SIGNATURE_LFH
  WriteInt buf, 4, verNeeded
  WriteInt buf, 6, flags
  WriteInt buf, 8, fi.compressionMethod
  WriteInt buf, 10, GetDosTime(fi.ModifiedDate)
  WriteInt buf, 12, GetDosDate(fi.ModifiedDate)
  WriteLong buf, 14, fi.CRC32
  WriteLong buf, 18, fi.CompressedSize
  WriteLong buf, 22, fi.UncompressedSize
  WriteInt buf, 26, nameLen
  WriteInt buf, 28, extraLen

  If Not WriteRawBytes(hFile, buf) Then Exit Function
  If Not WriteRawBytes(hFile, nameUtf8) Then Exit Function
  If extraLen > 0 Then
    If Not WriteRawBytes(hFile, baExtra) Then Exit Function
  End If
  If IsByteArrayUsable(encHeader) Then
    If Not WriteRawBytes(hFile, encHeader) Then Exit Function
  End If
  If IsByteArrayUsable(compressedData) Then
    If Not WriteRawBytes(hFile, compressedData) Then Exit Function
  End If
  If IsByteArrayUsable(baMac) Then
    If Not WriteRawBytes(hFile, baMac) Then Exit Function
  End If

  WriteLFH = True
End Function

Private Function WriteAesCentralDirectory(ByVal hFile As LongPtr, ByRef fileInfos() As AesFileInfo, ByVal count As Long, ByRef cdSize As Long) As Boolean

  Dim startPos As Long, i As Long
  startPos = GetFilePosition(hFile)
  For i = 0 To count - 1
    If Not WriteAesCDH(hFile, fileInfos(i)) Then Exit Function
  Next
  cdSize = GetFilePosition(hFile) - startPos
  WriteAesCentralDirectory = True

End Function

Private Function WriteAesCDH(ByVal hFile As LongPtr, ByRef fi As AesFileInfo) As Boolean
  ' WriteAesCDH
  Dim nameUtf8() As Byte, nameLen As Integer
  nameUtf8 = ToUtf8(fi.name)
  nameLen = UBound(nameUtf8) + 1

  Dim extraLen As Integer, baExtra() As Byte
  If fi.IsEncrypted And fi.compressionMethod = COMPRESSION_AES Then
    extraLen = 11
    baExtra = BuildAesExtraField(fi.EncryptionStrength, fi.OrigCompressionMethod)
  End If

  ' Flags must match the LFH exactly (bit 0 = encrypted, bit 11 = UTF-8 name).
  Dim flags As Integer
  If fi.IsEncrypted Then flags = flags Or &H1
  If fi.NameLenUtf8 <> Len(fi.name) Then flags = flags Or &H800

  Dim verNeeded As Integer
  verNeeded = IIf(fi.compressionMethod = COMPRESSION_AES, 51, 20)

  Dim extAttr As Long
  extAttr = IIf(fi.isFolder, FILE_ATTRIBUTE_DIRECTORY, FILE_ATTRIBUTE_NORMAL)

' CDH is 46 bytes fixed
  Dim buf(0 To 45) As Byte
  WriteLong buf, 0, SIGNATURE_CDH
  WriteInt buf, 4, verNeeded             ' version made by
  WriteInt buf, 6, verNeeded             ' version needed
  WriteInt buf, 8, flags
  WriteInt buf, 10, fi.compressionMethod
  WriteInt buf, 12, GetDosTime(fi.ModifiedDate)
  WriteInt buf, 14, GetDosDate(fi.ModifiedDate)
  WriteLong buf, 16, fi.CRC32
  WriteLong buf, 20, fi.CompressedSize
  WriteLong buf, 24, fi.UncompressedSize
  WriteInt buf, 28, nameLen
  WriteInt buf, 30, extraLen
  WriteInt buf, 32, 0                    ' comment length
  WriteInt buf, 34, 0                    ' disk number start
  WriteInt buf, 36, 0                    ' internal attributes
  WriteLong buf, 38, extAttr             ' external attributes
  WriteLong buf, 42, fi.LocalHeaderOffset

  If Not WriteRawBytes(hFile, buf) Then Exit Function
  If Not WriteRawBytes(hFile, nameUtf8) Then Exit Function
  If extraLen > 0 Then
    If Not WriteRawBytes(hFile, baExtra) Then Exit Function
  End If

  WriteAesCDH = True
End Function

Private Function WriteAesEOCD(ByVal hFile As LongPtr, ByVal entryCount As Long, ByVal cdSize As Long, ByVal cdOffset As Long) As Boolean
  Dim buf(0 To 21) As Byte
  WriteLong buf, 0, SIGNATURE_EOCD
  WriteInt buf, 4, 0                ' disk number
  WriteInt buf, 6, 0                ' disk with CD start
  WriteInt buf, 8, entryCount       ' entries on this disk
  WriteInt buf, 10, entryCount      ' total entries
  WriteLong buf, 12, cdSize
  WriteLong buf, 16, cdOffset
  WriteInt buf, 20, 0               ' comment length
  WriteAesEOCD = WriteRawBytes(hFile, buf)
End Function

Private Sub WriteLong(ByRef buf() As Byte, ByVal pos As Long, ByVal val As Long)
  ' Write a 4-byte little-endian Long into buf() at offset pos
  apiCopyMemory VarPtr(buf(pos)), VarPtr(val), 4
End Sub

Private Sub WriteInt(ByRef buf() As Byte, ByVal pos As Long, ByVal val As Long)
  ' Write a 2-byte little-endian Integer into buf() at offset pos
  Dim i As Long
  i = val And &HFFFF&
  If i > 32767 Then i = i - 65536
  Dim n As Integer
  n = CInt(i)
  apiCopyMemory VarPtr(buf(pos)), VarPtr(n), 2
End Sub

Private Function WriteRawBytes(ByVal hFile As LongPtr, ByRef data() As Byte) As Boolean

  If Not IsByteArrayUsable(data) Then
    WriteRawBytes = True
    Exit Function
  End If

  Dim bytesToWrite As Long, bytesWritten As Long, result As Long
  bytesToWrite = UBound(data) - LBound(data) + 1
  result = apiWriteFile(hFile, data(LBound(data)), bytesToWrite, bytesWritten, 0)
  WriteRawBytes = (result <> 0 And bytesWritten = bytesToWrite)
  If Not WriteRawBytes Then SetError "[WriteRawBytes] Write failed"

End Function

' Build the 11-byte WinZip AES extra field (header ID 0x9901)
Private Function BuildAesExtraField(ByVal strength As Byte, ByVal origMethod As Integer) As Byte()

  Dim b(0 To 10) As Byte
  b(0) = &H1: b(1) = &H99         ' Header ID 0x9901
  b(2) = &H7: b(3) = &H0          ' Data size = 7
  b(4) = &H2: b(5) = &H0          ' AE-2 (no CRC32 stored)
  b(6) = &H41: b(7) = &H45        ' Vendor "AE"
  b(8) = strength                  ' 1=AES128, 2=AES192, 3=AES256
  apiCopyMemory VarPtr(b(9)), VarPtr(origMethod), 2
  BuildAesExtraField = b

End Function

Private Function GetDosDate(Optional ByVal TargetDate As Date) As Integer
  ' Note: The ModDate and ModTime fields only accept 2 bytes (ie. integer).
  '       However, one of VBA's limitations is that it only has signed integers -
  '       that is a value of between -32,768 to 32,767. A 16-bit unsigned integer,
  '       on the other hand, falls between 0 to 65,535. Accordingly, depending on
  '       on the date/time, we need to delve into negative territory.

  If TargetDate = 0 Then TargetDate = Now
  Dim datePart As Long
  datePart = ((Year(TargetDate) - 1980) * 512&) Or (Month(TargetDate) * 32&) Or Day(TargetDate)
  datePart = datePart And &HFFFF&
  If datePart > 32767 Then datePart = datePart - 65536
  GetDosDate = datePart
End Function

Private Function GetDosTime(Optional ByVal TargetTime As Date) As Integer
  If TargetTime = 0 Then TargetTime = Now
  Dim TimePart As Long
  TimePart = (Hour(TargetTime) * 2048&) Or (Minute(TargetTime) * 32&) Or (Second(TargetTime) \ 2)
  TimePart = TimePart And &HFFFF&
  If TimePart > 32767 Then TimePart = TimePart - 65536
  GetDosTime = TimePart
End Function

Private Function GetFilePosition(ByVal hFile As LongPtr) As Long
  GetFilePosition = SetFilePointer(hFile, 0, 0, 1)  ' FILE_CURRENT = 1
End Function

' ------------------------------------------------------------------------------
' Deflate_ArchiveInt
' ------------------------------------------------------------------------------
' Compresses inputData using archiveint.dll's gzip filter, then strips the
' 10-byte gzip header and 8-byte gzip trailer to yield a raw DEFLATE stream.
' Returns an empty array on failure.
'
Private Function Deflate_ArchiveInt(ByRef inputData() As Byte) As Byte()
  Dim a       As LongPtr
  Dim e       As LongPtr
  Dim gz()    As Byte
  Dim used    As LongPtr
  Dim inSize  As Long
  Dim outSize As Long

  If Not IsByteArrayUsable(inputData) Then Exit Function

  inSize = UBound(inputData) - LBound(inputData) + 1

' Create writer: raw format + gzip filter
  a = archive_write_new()
  If a = 0 Then
    SetError "[Deflate_ArchiveInt] archive_write_new failed"
    Exit Function
  End If

  If archive_write_set_format_raw(a) <> ARCHIVE_OK Then
    SetError "[Deflate_ArchiveInt] set_format_raw failed"
    archive_write_free a
    Exit Function
  End If

  If archive_write_add_filter_gzip(a) <> ARCHIVE_OK Then
    SetError "[Deflate_ArchiveInt] add_filter_gzip failed"
    archive_write_free a
    Exit Function
  End If

  ' Apply compression level if non-default
  If m_CompressionLevel <> 6 Then
    Dim lvlOpt As String
    lvlOpt = "gzip:compression-level=" & m_CompressionLevel
    Dim lvlBytes() As Byte: lvlBytes = ToUtf8Z(lvlOpt)
    archive_write_set_options a, VarPtr(lvlBytes(0))
  End If

  ' Allocate output buffer: gzip overhead is tiny but we add generous headroom
  ' for incompressible data which can expand slightly
  Dim bufSize As Long
  bufSize = inSize + (inSize \ 100) + 1024
  ReDim gz(0 To bufSize - 1)

  If archive_write_open_memory(a, VarPtr(gz(0)), bufSize, used) <> ARCHIVE_OK Then
    SetError "[Deflate_ArchiveInt] archive_write_open_memory failed"
    archive_write_free a
    Exit Function
  End If

  e = archive_entry_new()
  If e = 0 Then
    SetError "[Deflate_ArchiveInt] archive_entry_new failed"
    archive_write_close a
    archive_write_free a
    Exit Function
  End If

  archive_entry_set_size e, inSize
  archive_entry_set_filetype e, AE_IFREG

  If archive_write_header(a, e) <> ARCHIVE_OK Then
    SetError "[Deflate_ArchiveInt] archive_write_header failed"
    archive_entry_free e
    archive_write_close a
    archive_write_free a
    Exit Function
  End If

  Dim written As LongPtr
  written = archive_write_data(a, VarPtr(inputData(LBound(inputData))), inSize)

  archive_entry_free e
  archive_write_finish_entry a
  archive_write_close a
  archive_write_free a

  If written < 0 Then
    SetError "[Deflate_ArchiveInt] archive_write_data failed"
    Exit Function
  End If

  Dim usedLen As Long: usedLen = CLng(used)

  ' Validate we have at least the gzip wrapper + 1 byte of DEFLATE data
  If usedLen <= GZIP_HEADER_LEN + GZIP_FOOTER_LEN Then
    SetError "[Deflate_ArchiveInt] output too small (" & usedLen & " bytes)"
    Exit Function
  End If

  ' Assert minimal gzip header (no FNAME/FEXTRA flags)
  ' Byte 0=1F, Byte 1=8B (magic), Byte 3=FLG must have bits 2 (FEXTRA) and
  ' 3 (FNAME) clear.  If either is set the header is longer than 10 bytes.
  If gz(0) <> &H1F Or gz(1) <> &H8B Then
    SetError "[Deflate_ArchiveInt] unexpected gzip magic bytes"
    Exit Function
  End If
  If (gz(3) And &HC) <> 0 Then
    SetError "[Deflate_ArchiveInt] gzip header has FEXTRA/FNAME - cannot strip safely"
    Exit Function
  End If

  ' Raw DEFLATE stream sits between the 10-byte header and 8-byte trailer
  outSize = usedLen - GZIP_HEADER_LEN - GZIP_FOOTER_LEN

  Dim deflated() As Byte
  ReDim deflated(0 To outSize - 1)
  apiCopyMemory VarPtr(deflated(0)), VarPtr(gz(GZIP_HEADER_LEN)), outSize

  Deflate_ArchiveInt = deflated
End Function

' ------------------------------------------------------------------------------
' Inflate_ArchiveInt
' ------------------------------------------------------------------------------
' Decompresses a raw DEFLATE stream by wrapping it in a minimal gzip shell and
' feeding it to archiveint.dll's read pipeline.
'
' The gzip footer (CRC32 + ISIZE) is zeroed because:
'   a) The decompressed data is unavailable before decompression.
'   b) libarchive does not validate the gzip trailer on read.
'
' Returns an empty array on failure.
'
Private Function Inflate_ArchiveInt(ByRef deflated() As Byte) As Byte()
  Dim a As LongPtr, entry As LongPtr, gz() As Byte, gzSize As Long
  Dim chunks() As Byte, p As LongPtr, sz As LongPtr, off As LongLong, total As LongLong, inSize As Long

  If Not IsByteArrayUsable(deflated) Then Exit Function

  inSize = UBound(deflated) - LBound(deflated) + 1
  gzSize = GZIP_HEADER_LEN + inSize + GZIP_FOOTER_LEN

  ' Build gzip wrapper
  ' ReDim initialises all bytes to zero - footer stays zero intentionally
  ReDim gz(0 To gzSize - 1)
  gz(0) = &H1F            ' gzip magic
  gz(1) = &H8B
  gz(2) = &H8             ' CM = deflate
  ' bytes 3-9: FLG=0, MTIME=0, XFL=0, OS=0 (all already zero)

  ' Copy raw DEFLATE payload into the wrapper
  apiCopyMemory VarPtr(gz(GZIP_HEADER_LEN)), VarPtr(deflated(LBound(deflated))), inSize
  a = archive_read_new()
  If a = 0 Then
    SetError "[Inflate_ArchiveInt] archive_read_new failed"
    Exit Function
  End If

  archive_read_support_format_raw a
  archive_read_support_filter_all a

  If archive_read_open_memory(a, VarPtr(gz(0)), gzSize) <> ARCHIVE_OK Then
    SetError "[Inflate_ArchiveInt] archive_read_open_memory failed"
    archive_read_free a
    Exit Function
  End If

  If archive_read_next_header(a, entry) <> ARCHIVE_OK Then
    SetError "[Inflate_ArchiveInt] archive_read_next_header failed"
    archive_read_close a
    archive_read_free a
    Exit Function
  End If

  ' Accumulate decompressed blocks into chunks()
  ' Initial allocation: 8x input size (generous for typical compression ratios)
  Dim initSize As Long
  initSize = inSize * 8
  If initSize < 65536 Then initSize = 65536
  ReDim chunks(0 To initSize - 1)

  Do While archive_read_data_block(a, p, sz, off) = ARCHIVE_OK
    Dim needed As LongLong
    needed = off + CLng(sz)

    If needed > CLngLng(UBound(chunks) + 1) Then
      ReDim Preserve chunks(0 To CLng(needed * 2) - 1)
    End If

    apiCopyMemory VarPtr(chunks(0)) + off, p, CLng(sz)
    total = needed
  Loop

  archive_read_close a
  archive_read_free a

  If total = 0 Then
    SetError "[Inflate_ArchiveInt] no data returned"
    Exit Function
  End If

  ReDim Preserve chunks(0 To CLng(total) - 1)
  Inflate_ArchiveInt = chunks
End Function

Private Sub LogMessage(ByVal level As ArcLogLevel, ByVal msg As String)
  ' Writes a message at the given level to the configured output(s).
  ' Respects m_LogLevel - messages below the threshold are silently dropped.
  If level < m_LogLevel Then Exit Sub

  Dim prefix As String
  Select Case level
    Case logDebug:   prefix = "[DBG] "
    Case logInfo:    prefix = "[INF] "
    Case logWarning: prefix = "[WRN] "
    Case logError:   prefix = "[ERR] "
    Case Else:       prefix = "[   ] "
  End Select

  Debug.Print prefix & msg
  
End Sub

Private Sub ClearError()
  m_LastError = ""
End Sub

Private Function FirstNonIsoSafeSegment() As String
  ' Returns the first queued entry name containing a path SEGMENT that has no
  ' ASCII character at all - the case libarchive's iso9660 writer silently drops
  ' (taking any nested files with it). This is forensically unhelpful.
  ' Returns "" if every segment has at least one ASCII character to anchor a base name.
  Dim i As Long, segs() As String, s As Long, seg As String
  For i = 0 To m_QueueCount - 1
    segs = Split(Replace$(m_Queue(i).name, "\", "/"), "/")
    For s = LBound(segs) To UBound(segs)
      seg = segs(s)
      If Len(seg) > 0 Then
        If Not SegmentHasAscii(seg) Then
          FirstNonIsoSafeSegment = seg
          Exit Function
        End If
      End If
    Next s
  Next i
End Function

Private Function SegmentHasAscii(ByVal seg As String) As Boolean
  ' True if seg contains at least one ASCII character.
  Dim k As Long, c As Long
  For k = 1 To Len(seg)
    c = AscW(Mid$(seg, k, 1)) And &HFFFF&
    If c >= 1 And c <= 127 Then
      SegmentHasAscii = True
      Exit Function
    End If
  Next k
End Function

Private Sub SetError(ByVal msg As String)
  m_LastError = msg
  LogMessage logError, msg
End Sub

Private Function AssertMode(ByVal required As ArchiveMode, ByVal caller As String) As Boolean
  ' Returns True if the current mode matches the required mode.
  ' If not, sets a descriptive error and returns False.
  ' Pass arcModeNone to assert that no archive is currently open.
  If m_Mode = required Then
    AssertMode = True
    Exit Function
  End If

  Select Case required
  Case arcModeNone
    SetError caller & ": an archive is already open. Call CloseFile first."
  Case arcModeRead
    If m_Mode = arcModeNone Then
      SetError caller & ": no archive is open. Call OpenFile first."
    Else
      SetError caller & ": archive is open in write mode. Use read-mode methods."
    End If
  Case arcModeWrite
    If m_Mode = arcModeNone Then
      SetError caller & ": no archive is open. Call NewFile first."
    Else
      SetError caller & ": archive is open in read mode. Use write-mode methods."
    End If
  End Select
End Function

Private Function ToUtf8Internal(ByVal s As String, Optional ByVal NullTerminate As Boolean = False) As Byte()
    Dim emptyBytes() As Byte
    If Len(s) = 0 Then ToUtf8Internal = emptyBytes: Exit Function
    
    Dim cbNeeded As Long
    cbNeeded = WideCharToMultiByte(CP_UTF8, 0, StrPtr(s), Len(s), 0, 0, 0, 0)
    If cbNeeded <= 0 Then ToUtf8Internal = emptyBytes: Exit Function
    
    Dim buf() As Byte
    ReDim buf(0 To cbNeeded - 1 + IIf(NullTerminate, 1, 0))
    WideCharToMultiByte CP_UTF8, 0, StrPtr(s), Len(s), VarPtr(buf(0)), cbNeeded, 0, 0
    ToUtf8Internal = buf
End Function

Private Function ToUtf8(ByVal s As String) As Byte()
    ToUtf8 = ToUtf8Internal(s, False)
End Function

Private Function ToUtf8Z(ByVal s As String) As Byte()
    ToUtf8Z = ToUtf8Internal(s, True)
End Function

Private Function PtrToStringW(ByVal ptr As LongPtr) As String
  ' Reads a null-terminated UTF-16LE string from a raw pointer (as returned by
  ' libarchive's archive_entry_pathname_w).
  If ptr = 0 Then Exit Function
  Dim cch As Long: cch = lstrlenW(ptr)
  If cch = 0 Then Exit Function
  Dim buf() As Byte
  ReDim buf(0 To cch * 2 - 1)
  apiCopyMemory VarPtr(buf(0)), ptr, cch * 2
  PtrToStringW = buf
End Function

Private Function PtrToStringA(ByVal ptr As LongPtr) As String
  ' Reads a null-terminated ANSI/UTF-8 string from a raw pointer.
  ' Used for archive_error_string which returns char*.
  If ptr = 0 Then Exit Function
  Dim cb As Long
  cb = lstrlenA(ptr)
  If cb = 0 Then Exit Function
  Dim buf() As Byte
  ReDim buf(0 To cb - 1)
  apiCopyMemory VarPtr(buf(0)), ptr, cb
  Dim cch As Long
  cch = MultiByteToWideChar(CP_UTF8, 0, VarPtr(buf(0)), cb, 0, 0)
  If cch <= 0 Then Exit Function
  Dim wbuf() As Byte
  ReDim wbuf(0 To cch * 2 - 1)
  MultiByteToWideChar CP_UTF8, 0, VarPtr(buf(0)), cb, VarPtr(wbuf(0)), cch
  PtrToStringA = wbuf
End Function

Private Function IsByteArrayUsable(ByRef data() As Byte) As Boolean
  On Error Resume Next
  IsByteArrayUsable = (UBound(data) >= LBound(data))
  On Error GoTo 0
End Function

Private Function LastArchiveError(ByVal h As LongPtr) As String
  ' Returns libarchive's human-error string for a handle
  ' Currently using it to deal with an edge case re: ISO, but useful nonetheless
  If h = 0 Then Exit Function
  LastArchiveError = PtrToStringA(archive_error_string(h))
End Function

Private Function FileExists(ByVal path As String) As Boolean
  Dim attrs As Long
  attrs = apiGetFileAttributesW(StrPtr(path))
  If attrs = INVALID_FILE_ATTRIBUTES Then Exit Function
  FileExists = (attrs And FILE_ATTRIBUTE_DIRECTORY) = 0
End Function

Private Function FolderExists(ByVal path As String) As Boolean
  Dim attrs As Long
  attrs = apiGetFileAttributesW(StrPtr(path))
  If attrs = INVALID_FILE_ATTRIBUTES Then Exit Function
  FolderExists = (attrs And FILE_ATTRIBUTE_DIRECTORY) <> 0
End Function

Private Function GetFileSize64(ByVal path As String) As LongLong
  GetFileSize64 = -1
  Dim hFile As LongPtr
  hFile = apiCreateFileW(StrPtr(path), GENERIC_READ, FILE_SHARE_READ, 0, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, 0)
  If hFile = INVALID_HANDLE_VALUE Then Exit Function
  Dim rawSize As Currency
  If apiGetFileSizeEx(hFile, rawSize) = 0 Then
    apiCloseHandle hFile
    Exit Function
  End If
  apiCloseHandle hFile
  Dim llSize As LongLong
  apiCopyMemory VarPtr(llSize), VarPtr(rawSize), 8
  GetFileSize64 = llSize
End Function

Private Function FileModifiedDate(ByVal path As String) As Date
  FileModifiedDate = Now  ' safe default

  Dim fd As WIN32_FIND_DATA
  Dim hFind As LongPtr
  hFind = apiFindFirstFileW(StrPtr(path), fd)
  If hFind = INVALID_HANDLE_VALUE Then Exit Function
  apiFindClose hFind

  ' Convert FILETIME (UTC) -> local FILETIME -> SYSTEMTIME -> VBA Date
  Dim localFT As FILETIME
  Dim st      As SYSTEMTIME

  If apiFileTimeToLocalFileTime(fd.ftLastWriteTime, localFT) = 0 Then Exit Function
  If apiFileTimeToSystemTime(localFT, st) = 0 Then Exit Function

  On Error Resume Next
  FileModifiedDate = DateSerial(st.wYear, st.wMonth, st.wDay) + TimeSerial(st.wHour, st.wMinute, st.wSecond)
  On Error GoTo 0
End Function

Private Function ReadFileToBytes(ByVal path As String) As Byte()
  Dim llSize As LongLong
  llSize = GetFileSize64(path)
  If llSize < 0 Then SetError "[ReadFileToBytes] cannot stat " & path: Exit Function
  If llSize = 0 Then Exit Function
  If llSize >= 2 ^ 31 Then SetError "[ReadFileToBytes] file too large: " & path: Exit Function

  Dim FileSize As Long: FileSize = CLng(llSize)
  Dim buf() As Byte: ReDim buf(0 To FileSize - 1)

  Dim hFile As LongPtr
  hFile = apiCreateFileW(StrPtr(path), GENERIC_READ, FILE_SHARE_READ, 0, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, 0)
  If hFile = INVALID_HANDLE_VALUE Then SetError "[ReadFileToBytes] Cannot open " & path: Exit Function

  Dim totalRead As Long, bytesRead As Long, remaining As Long
  remaining = FileSize
  Do While remaining > 0
    Dim chunkSize As Long: chunkSize = IIf(remaining > STREAM_CHUNK_SIZE, STREAM_CHUNK_SIZE, remaining)
    If apiReadFile(hFile, buf(totalRead), chunkSize, bytesRead, 0) = 0 Then
      SetError "[ReadFileToBytes] Read failed: " & path
      apiCloseHandle hFile: Exit Function
    End If
    If bytesRead = 0 Then Exit Do
    totalRead = totalRead + bytesRead
    remaining = remaining - bytesRead
  Loop

  apiCloseHandle hFile
  If totalRead < FileSize Then ReDim Preserve buf(0 To totalRead - 1)
  ReadFileToBytes = buf
End Function

Private Function DateToUnix(ByVal d As Date) As Long
  On Error Resume Next
  DateToUnix = CLng((d - UNIX_EPOCH_OFFSET) * 86400#)
  On Error GoTo 0
End Function

Private Function UnixToDate(ByVal unix As LongLong) As Date
  On Error Resume Next
  UnixToDate = CDate(UNIX_EPOCH_OFFSET + CDbl(unix) / 86400#)
  If Err.Number <> 0 Then UnixToDate = Now
  On Error GoTo 0
End Function

Public Function GetArchiveIntVersionString() As String
  Dim p As LongPtr
  p = archive_version_string()
  If p = 0 Then Exit Function
  GetArchiveIntVersionString = PtrToStringA(p)
End Function

Public Function GetArchiveIntVersionNumber() As String
  GetArchiveIntVersionNumber = CStr(archive_version_number())
End Function

Public Function GetArchiveIntVersionDetails() As String
  Dim p As LongPtr
  p = archive_version_details()
  If p = 0 Then Exit Function
  GetArchiveIntVersionDetails = PtrToStringA(p)
End Function

