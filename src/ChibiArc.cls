Private Sub Class_Initialize()
  m_Mode = arcModeNone
  m_Type = atAuto
  m_LogLevel = logInfo
  m_ProgressInterval = 1
  m_Encryption = aeNone
  m_CompressionLevel = 6
  EnsureArchiveInt
  LogMessage logDebug, "--- ChibiArc Initialised ---"
End Sub

Private Sub Class_Terminate()
  On Error Resume Next
  CloseFile
  If m_VirtDiskHandle <> 0 Then
    If m_AutoDismountOnTerminate Then
      ' Opted in: fully detach the virtual disk (releases the drive
      ' letter and raises IsoDismounted) before releasing the handle.
      DismountISO
    Else
      ' Default: only release the handle- don't detach the virtual disk.
      ' PERMANENT_LIFETIME = the mount persists beyond this class instance.
      apiCloseHandle m_VirtDiskHandle
      m_VirtDiskHandle = 0
      m_MountedIsoPath = ""
      m_MountedDrive = ""
    End If
  End If
  On Error GoTo 0
End Sub

Public Function NewFile(ByVal filePath As String, _
                        Optional ByVal ArchiveType As arcType = atAuto, _
                        Optional ByVal PassPhrase As String = "") As Boolean
                        
  ' Opens the class in write mode targeting FilePath.
  ' ArchiveType defaults to atAuto (detected from extension; falls back to ZIP).
  ' Passphrase is optional; if supplied it is stored and applied at SaveFile time.
  ' If AES encryption is also set, libarchive is used only for DEFLATE; the pure
  ' VBA pipeline handles key derivation, encryption, and ZIP serialisation.
  ClearError
  If Not AssertMode(arcModeNone, "NewFile") Then Exit Function
  If Not EnsureArchiveInt() Then Exit Function

  If FileExists(filePath) Then
    SetError "[NewFile] File already exists: " & filePath
    Exit Function
  End If

  If Not EnsureParentDirOfFile(filePath) Then
    SetError "[NewFile] Cannot create output folder for: " & filePath
    Exit Function
  End If

  m_SourceFile = filePath
  m_Passphrase = PassPhrase
  If ArchiveType = atAuto Then
    m_Type = DetectTypeFromPath(filePath)
  Else
    m_Type = ArchiveType
  End If

  m_Mode = arcModeWrite
  Set m_FolderIndex = CreateObject("Scripting.Dictionary")
  m_FolderIndex.CompareMode = 1   ' vbTextCompare = case-insensitive, matches
  NewFile = True
  LogMessage logInfo, "--- NewFile: " & filePath & " (type=" & ArchiveTypeName(m_Type) & ") ---"
End Function

Public Function OpenFile(ByVal filePath As String, Optional ByVal PassPhrase As String = "") As Boolean
  ' Opens an existing archive in read mode. Passphrase is optional, but obviously required for encrypted archives.
  ' The scan cache is populated lazily on the first property or Dir() call.
  ClearError
  If Not AssertMode(arcModeNone, "OpenFile") Then Exit Function
  If Not EnsureArchiveInt() Then Exit Function

  If Not FileExists(filePath) Then
    SetError "[OpenFile] File not found: " & filePath
    Exit Function
  End If

  m_SourceFile = filePath
  m_Passphrase = PassPhrase

  If Not OpenLibArchive(filePath) Then Exit Function
  m_Mode = arcModeRead

  Dim detectedType As arcType
  detectedType = FormatCodeToArcType(archive_format(m_hRead))
  If detectedType <> atAuto Then
    m_Type = detectedType
    LogMessage logDebug, "[OpenFile] Format detected as " & ArchiveTypeName(m_Type) & " (code=0x" & Hex$(archive_format(m_hRead)) & ")"
  Else
    m_Type = DetectTypeFromPath(filePath)
    LogMessage logDebug, "[OpenFile] Format not recognised by libarchive, using extension: " & ArchiveTypeName(m_Type)
  End If

  LogMessage logInfo, "[OpenFile] " & filePath
  OpenFile = True
End Function

Public Function SaveFile() As Boolean
  ' Serialises the pending queue to m_SourceFile.
  ' For ZIP + AES encryption the pure VBA pipeline is used.
  ' For all other combinations (including basic ZipCrypto), libarchive handles the write end-to-end.
  ' Closes the archive on completion (success or failure).

  ClearError
  If Not AssertMode(arcModeWrite, "SaveFile") Then Exit Function
  If m_QueueCount = 0 Then
    SetError "[SaveFile] No entries added."
    Exit Function
  End If

  ' It appears that ISO9660 cannot safely store a path segment that has
  ' a non-ASCII-representable base name (e.g. a purely non-ASCII foldername
  ' or filename such as CJK script). I discovered this the painful way, and
  ' I'm keen to fix it (if at all possible, and it seems like it should be
  ' possible). What currently happens is that any such entry is dropped, and this
  ' includes all the files, etc in it (if it happens to be a folder). This is
  ' a data loss - it's some of an edge case, but given that I have Japanese language
  ' files and folders.
  ' TODO (v1.2?): root-cause the iso9660 non-ASCII drop. The commented folder-
  ' header rc logging in WriteOneEntry (with LastArchiveError) is the breadcrumb.
  If m_Type = atIso Then
    Dim isoBad As String
    isoBad = FirstNonIsoSafeSegment()
    If Len(isoBad) > 0 Then
      SetError "[SaveFile] ISO cannot store the non-ASCII entry name '" & isoBad & "' without data loss. " & _
               "Use ZIP or 7z for this content, or rename the entry. " & _
               "(Full Unicode ISO name support is tracked for a future release.)"
      Exit Function
    End If
  End If

  If m_Type = atZip And m_Encryption >= aeAes128 And m_Encryption <= aeAes256 Then
    Dim i As Long
    Dim estimatedSize As LongLong
    For i = 0 To m_QueueCount - 1
      If Len(m_Queue(i).SourcePath) > 0 Then
        estimatedSize = estimatedSize + GetFileSize64(m_Queue(i).SourcePath)
      ElseIf IsByteArrayUsable(m_Queue(i).data) Then
        estimatedSize = estimatedSize + UBound(m_Queue(i).data) + 1
      End If
      If estimatedSize > 2000000000^ Then
        SetError "[SaveFile] Estimated uncompressed input exceeds 2 GB. Zip64 is not supported."
        Exit Function
      End If
    Next
  End If

  m_OperationReport = ""

  Dim tStart As Double, result As Boolean
  tStart = Timer
  If m_Type = atZip And m_Encryption >= aeAes128 Then
    ' AES path: pure VBA ZIP serialiser with archiveint DEFLATE.
    ' m_TotalCompressedSize is accumulated per-entry inside SaveZip_AES.
    result = SaveZip_AES()
  Else
    ' Standard path: libarchive end-to-end.
    result = SaveLibArchive()
    ' SaveLibArchive has no per-entry hook for compressed size, so we stat
    ' the output file on success - the same "honest on-disk footprint"
    ' approach used by EnsureScanned in read mode. m_SourceFile is still
    ' populated here; CloseFile (below) wipes it via ResetState.
    If result Then
      Dim outFileSize As LongLong
      outFileSize = GetFileSize64(m_SourceFile)
      If outFileSize >= 0 Then m_TotalCompressedSize = outFileSize
    End If
  End If

  m_LastOperationTime = Timer - tStart
  LogMessage logInfo, "[SaveFile] Completed in " & Format(m_LastOperationTime, "0.000") & "s"
  SaveFile = result
  CloseFile
End Function

Public Sub CloseFile()
  ' Tears down any open libarchive handles and resets all state.
  ' Safe to call at any time, including after SaveFile.

  CloseLibArchive
  ResetState
  LogMessage logInfo, "[CloseFile] File closed"
End Sub

Public Function ArchiveIntAvailable() As Boolean
  ArchiveIntAvailable = m_ArchiveIntAvailable
End Function

Public Function MountISO(ByVal isoPath As String, Optional ByVal ReadOnly As Boolean = True, Optional ByVal AutoDriveLetter As Boolean = True) As String
  If Len(isoPath) = 0 Then Exit Function

  Dim existing As String
  existing = TryGetExistingMount(isoPath)
  If existing <> "" Then
    m_MountedIsoPath = isoPath
    m_MountedDrive = existing
    MountISO = existing
    RaiseEvent IsoMounted(isoPath, existing)
    Exit Function
  End If

  Dim tVst As VIRTUAL_STORAGE_TYPE
  Dim tOvdp As OPEN_VIRTUAL_DISK_PARAMETERS
  Dim tAvdp As ATTACH_VIRTUAL_DISK_PARAMETERS
  Dim hDisk As LongPtr
  Dim pathBuffer As String
  Dim pathSize As Long
  Dim accessMask As Long
  Dim attachFlags As Long

  tVst.DeviceId = VIRTUAL_STORAGE_TYPE_DEVICE_ISO
  tVst.VendorId = StringToGuid(VIRTUAL_STORAGE_TYPE_VENDOR_MICROSOFT)
  tOvdp.Version = OPEN_VIRTUAL_DISK_VERSION_1
  tOvdp.RWDepth = OPEN_VIRTUAL_DISK_RW_DEPTH_DEFAULT
  tAvdp.Version = ATTACH_VIRTUAL_DISK_VERSION_1

  accessMask = VIRTUAL_DISK_ACCESS_READ Or VIRTUAL_DISK_ACCESS_GET_INFO
  attachFlags = ATTACH_VIRTUAL_DISK_FLAG_PERMANENT_LIFETIME
  If ReadOnly Then attachFlags = attachFlags Or ATTACH_VIRTUAL_DISK_FLAG_READ_ONLY
  If Not AutoDriveLetter Then attachFlags = attachFlags Or ATTACH_VIRTUAL_DISK_FLAG_NO_DRIVE_LETTER

  If OpenVirtualDisk(VarPtr(tVst), StrPtr(isoPath), accessMask, 0&, VarPtr(tOvdp), hDisk) <> S_OK Then
    SetError "[MountISO] Failed to open virtual disk: " & isoPath
    Exit Function
  End If

  If AttachVirtualDisk(hDisk, 0&, attachFlags, 0&, VarPtr(tAvdp), 0&) <> S_OK Then
    apiCloseHandle hDisk
    SetError "[MountISO] Failed to attach virtual disk: " & isoPath
    Exit Function
  End If

  pathSize = MAX_PATH * 2
  pathBuffer = String$(MAX_PATH, vbNullChar)
  If GetVirtualDiskPhysicalPath(hDisk, pathSize, StrPtr(pathBuffer)) <> S_OK Then
    apiCloseHandle hDisk
    SetError "[MountISO] Failed to retrieve virtual disk path."
    Exit Function
  End If

  pathBuffer = CutNull(pathBuffer)
  m_VirtDiskHandle = hDisk
  m_MountedIsoPath = isoPath
  m_MountedDrive = GetDriveLetterFromDevicePath(pathBuffer)
  MountISO = m_MountedDrive
  RaiseEvent IsoMounted(isoPath, m_MountedDrive)
End Function

Public Function MountISOToLetter(ByVal isoPath As String, ByVal DriveLetter As String, Optional ByVal ReadOnly As Boolean = True) As String
  If Len(DriveLetter) = 0 Then Exit Function
  If Right$(DriveLetter, 1) <> "\" Then DriveLetter = DriveLetter & "\"

  Dim drive As String
  drive = MountISO(isoPath, ReadOnly, False)
  If drive = "" Then Exit Function

  Dim volumeName As String
  volumeName = GetVolumeNameFromDevicePath(drive)
  If Len(volumeName) = 0 Then
    SetError "[MountISOToLetter] Failed to resolve volume name for manual mount."
    Exit Function
  End If

  If SetVolumeMountPointW(StrPtr(DriveLetter), StrPtr(volumeName)) <> 1 Then
    SetError "[MountISOToLetter] Failed to assign drive letter " & DriveLetter
    Exit Function
  End If

  m_MountedDrive = DriveLetter
  MountISOToLetter = DriveLetter
  RaiseEvent IsoMounted(isoPath, DriveLetter)
End Function

Public Sub DismountISO(Optional ByVal Force As Boolean = False)
  If m_VirtDiskHandle = 0 Then Exit Sub
  On Error GoTo EH

  Dim isoPathForEvent As String
  isoPathForEvent = m_MountedIsoPath

  DetachVirtualDisk m_VirtDiskHandle, DETACH_VIRTUAL_DISK_FLAG_NONE, 0&
  apiCloseHandle m_VirtDiskHandle

  m_VirtDiskHandle = 0
  m_MountedIsoPath = ""
  m_MountedDrive = ""
  RaiseEvent IsoDismounted(isoPathForEvent)
  Exit Sub
EH:
  SetError "[DismountISO] " & Err.Description
End Sub

Public Function IsISOMounted(Optional ByVal isoPath As String = "") As Boolean
  If Len(isoPath) > 0 Then
    IsISOMounted = (TryGetExistingMount(isoPath) <> "")
  Else
    IsISOMounted = (m_VirtDiskHandle <> 0)
  End If
End Function

