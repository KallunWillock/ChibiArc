Private Type QueueEntry
  name            As String   ' path as it will appear inside the archive
  SourcePath      As String   ' disk path (empty if Data() is populated)
  data()          As Byte     ' in-memory payload (used when SourcePath = "")
  isFolder        As Boolean
  IsStreamed      As Boolean
  ModifiedDate    As Date
  FileSize        As LongLong
End Type

Private Type ScannedEntry
  name            As String
  isFolder        As Boolean
  UncompressedSize As LongLong
  ModifiedUnix    As LongLong
End Type

Private Type ArchiveCryptoState
  hPbkdf2Alg      As LongPtr
  hAesAlg         As LongPtr
  hAesKey         As LongPtr
  AesKeyObjLen    As Long
  AesKeyObjData() As Byte
  hHmacAlg        As LongPtr
  hHmacHash       As LongPtr
  HmacLen         As Long
  Nonce(0 To 15)  As Byte
  EncrData()      As Byte
  EncrPos         As Long
End Type

' Per-entry metadata recorded during the local-file-header pass, then reused
' when writing the central directory.
Private Type AesFileInfo
  name                As String
  isFolder            As Boolean
  IsEncrypted         As Boolean
  CRC32               As Long
  UncompressedSize    As Long      ' capped at ~2 GB; Zip64 not yet implemented
  CompressedSize      As Long      ' includes enc header + MAC overhead
  compressionMethod   As Integer   ' 99 (AES) or 8 (DEFLATE) or 0 (store)
  OrigCompressionMethod As Integer ' actual compression before AES wrapping
  ModifiedDate        As Date
  LocalHeaderOffset   As Long
  EncryptionStrength  As Byte
  NameLenUtf8         As Long
End Type

Private Enum LibArchiveResult
  ARCHIVE_FATAL = -30
  ARCHIVE_FAILED = -25
  ARCHIVE_WARN = -20
  ARCHIVE_RETRY = -10
  ARCHIVE_OK = 0
  ARCHIVE_EOF = 1
End Enum

